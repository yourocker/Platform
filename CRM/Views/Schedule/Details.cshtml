@using CRM.ViewModels.Schedule
@model BookingDetailsViewModel

@{
    var booking = Model.Booking;
    ViewData["Title"] = string.IsNullOrWhiteSpace(booking.Title) ? "Детали бронирования" : booking.Title;
    ViewData["ModalSize"] = "xl";
    var isModal = string.Equals(Context.Request.Query["modal"], "true", StringComparison.OrdinalIgnoreCase);
    var controlId = $"booking_details_{booking.Id:N}";
}

<style>
    .booking-details-shell {
        background: #fff;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .booking-details-header {
        padding: 1.5rem 1.5rem 1.25rem;
        border-bottom: 1px solid rgba(15, 23, 42, 0.08);
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.92), #fff);
    }

    .booking-details-title {
        font-size: 1.4rem;
        font-weight: 700;
        line-height: 1.3;
    }

    .booking-details-meta {
        color: #6b7280;
        font-size: 0.92rem;
    }

    .booking-details-content {
        padding: 1.5rem;
    }

    .booking-details-section {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 16px;
        padding: 1rem 1.1rem;
        height: 100%;
        background: #fff;
    }

    .booking-details-section-title {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #6b7280;
        font-weight: 700;
        margin-bottom: 0.9rem;
    }

    .booking-details-grid {
        display: grid;
        grid-template-columns: minmax(150px, 190px) minmax(0, 1fr);
        gap: 0.6rem 1rem;
    }

    .booking-details-grid dt {
        margin: 0;
        color: #6b7280;
        font-weight: 600;
    }

    .booking-details-grid dd {
        margin: 0;
    }

    .booking-details-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .booking-details-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.45rem 0.7rem;
        border-radius: 999px;
        background: #f8fafc;
        border: 1px solid rgba(15, 23, 42, 0.08);
        color: #1f2937;
        font-size: 0.92rem;
    }

    .booking-details-empty {
        color: #6b7280;
    }

    .booking-details-custom-list {
        display: grid;
        gap: 0.9rem;
    }

    .booking-details-custom-item {
        padding-bottom: 0.9rem;
        border-bottom: 1px solid rgba(15, 23, 42, 0.08);
    }

    .booking-details-custom-item:last-child {
        padding-bottom: 0;
        border-bottom: 0;
    }

    .booking-details-custom-label {
        color: #6b7280;
        font-size: 0.88rem;
        font-weight: 600;
        margin-bottom: 0.35rem;
    }

    .booking-details-custom-values {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .booking-details-actions {
        margin-top: 1rem;
    }

    body[data-crm-modal-page="true"] .booking-details-shell {
        box-shadow: none;
    }
</style>

@if (isModal)
{
    <div class="container-fluid">
        <div class="booking-details-shell">
            <div class="booking-details-header">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                    <div>
                        <div class="booking-details-title">@(string.IsNullOrWhiteSpace(booking.Title) ? "Без заголовка" : booking.Title)</div>
                        <div class="booking-details-meta mt-1">
                            Дата создания: @booking.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="booking-details-meta mb-1">Статус</div>
                        <span class="badge bg-secondary-subtle text-dark border">@((booking.Status?.Name ?? "Не указан"))</span>
                    </div>
                </div>
            </div>

            <div class="booking-details-content">
                <ul class="nav nav-tabs" id="@($"{controlId}_tabs")" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active"
                                id="@($"{controlId}_main_tab")"
                                data-bs-toggle="tab"
                                data-bs-target="#@($"{controlId}_main")"
                                type="button"
                                role="tab"
                                aria-controls="@($"{controlId}_main")"
                                aria-selected="true">
                            Основное
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link"
                                id="@($"{controlId}_events_tab")"
                                data-bs-toggle="tab"
                                data-bs-target="#@($"{controlId}_events")"
                                type="button"
                                role="tab"
                                aria-controls="@($"{controlId}_events")"
                                aria-selected="false">
                            События
                        </button>
                    </li>
                </ul>

                <div class="tab-content border border-top-0 rounded-bottom p-4 bg-white">
                    <div class="tab-pane fade show active"
                         id="@($"{controlId}_main")"
                         role="tabpanel"
                         aria-labelledby="@($"{controlId}_main_tab")">
                        <partial name="_DetailsMain" model="Model" />
                    </div>
                    <div class="tab-pane fade"
                         id="@($"{controlId}_events")"
                         role="tabpanel"
                         aria-labelledby="@($"{controlId}_events_tab")">
                        <partial name="~/Views/Shared/_EntityTimeline.cshtml" model="Model.TimelineEvents" />
                    </div>
                </div>

                <div class="booking-details-actions d-flex gap-2">
                    <button type="button"
                            crm-button
                            variant="outline-secondary"
                            id="backToBookingBtn"
                            data-booking-id="@booking.Id">
                        Назад
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="container-fluid px-4">
        <crm-page-header title="" icon="" subtitle=""></crm-page-header>

        <div class="row justify-content-center">
            <div class="col-xl-10">
                <div class="booking-details-shell">
                    <div class="booking-details-header">
                        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                            <div>
                                <div class="booking-details-title">@(string.IsNullOrWhiteSpace(booking.Title) ? "Без заголовка" : booking.Title)</div>
                                <div class="booking-details-meta mt-1">Просмотр записи в расписании</div>
                            </div>
                            <div class="text-end">
                                <div class="booking-details-meta mb-1">Статус</div>
                                <span class="badge bg-secondary-subtle text-dark border">@((booking.Status?.Name ?? "Не указан"))</span>
                            </div>
                        </div>
                    </div>

                    <div class="booking-details-content">
                        <ul class="nav nav-tabs" id="@($"{controlId}_tabs")" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active"
                                        id="@($"{controlId}_main_tab")"
                                        data-bs-toggle="tab"
                                        data-bs-target="#@($"{controlId}_main")"
                                        type="button"
                                        role="tab"
                                        aria-controls="@($"{controlId}_main")"
                                        aria-selected="true">
                                    Основное
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link"
                                        id="@($"{controlId}_events_tab")"
                                        data-bs-toggle="tab"
                                        data-bs-target="#@($"{controlId}_events")"
                                        type="button"
                                        role="tab"
                                        aria-controls="@($"{controlId}_events")"
                                        aria-selected="false">
                                    События
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content border border-top-0 rounded-bottom p-4 bg-white">
                            <div class="tab-pane fade show active"
                                 id="@($"{controlId}_main")"
                                 role="tabpanel"
                                 aria-labelledby="@($"{controlId}_main_tab")">
                                <partial name="_DetailsMain" model="Model" />
                            </div>
                            <div class="tab-pane fade"
                                 id="@($"{controlId}_events")"
                                 role="tabpanel"
                                 aria-labelledby="@($"{controlId}_events_tab")">
                                <partial name="~/Views/Shared/_EntityTimeline.cshtml" model="Model.TimelineEvents" />
                            </div>
                        </div>

                        <div class="booking-details-actions d-flex gap-2">
                            <a asp-action="Index" crm-button variant="outline-secondary">К расписанию</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.getElementById('backToBookingBtn')?.addEventListener('click', function () {
            const bookingId = this.getAttribute('data-booking-id');
            if (!bookingId || !window.parent || window.parent === window) {
                return;
            }

            window.parent.postMessage({
                type: 'crm-booking-details-back',
                bookingId
            }, window.location.origin);
        });
    </script>
}

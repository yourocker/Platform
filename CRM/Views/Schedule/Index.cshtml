                if (slotAvailabilityState.checked && !slotAvailabilityState.canSave) {
                    return;
                }

                let allowOutOfHours = false;
                const startValue = parseDate(modalStart.value);
                const endValue = parseDate(modalEnd.value);
                if (startValue && endValue) {
                    const outsideWorkHours = isOutsideCompanyWorkHours(startValue, endValue);
                    if (!isEditMode && outsideWorkHours && createSource !== 'button') {
                        modalResult.innerHTML = '<span class="text-danger">Запись вне рабочего времени можно создать только через кнопку "Добавить запись".</span>';
                        return;
                    }

                    if (outsideWorkHours) {
                        const accepted = confirm('Время записи выходит за рамки рабочего графика компании. Сохранить такую запись?');
                        if (!accepted) {
                            return;
                        }

                        allowOutOfHours = true;
                    }
                }

                const url = isEditMode ? '/Schedule/UpdateBooking' : '/Schedule/CreateBooking';

                try {
                    const submitBooking = async (allowOutOfHoursFlag) => {
                        const formData = buildBookingFormData({ allowOutOfHours: allowOutOfHoursFlag });
                        const response = await fetch(url, {
                            method: 'POST',
                            body: formData
                        });
                        return response.json();
                    };

                    let result = await submitBooking(allowOutOfHours);

                    const needsOutOfHoursConfirmation = !result.success &&
                        !allowOutOfHours &&
                        String(result.message || '').toLowerCase().includes('подтвердите') &&
                        String(result.message || '').toLowerCase().includes('вне рабочего времени');

                    if (needsOutOfHoursConfirmation) {
                        const accepted = confirm('Время записи выходит за рамки рабочего графика компании. Сохранить такую запись?');
                        if (!accepted) {
                            return;
                        }

                        result = await submitBooking(true);
                    }

                    if (result.success) {
                        bookingModal.hide();
                        calendar.refetchEvents();
                    } else {
                        modalResult.innerHTML = `<span class="text-danger">${result.message || 'Не удалось сохранить запись.'}</span>`;
                    }
                } catch {
                    modalResult.innerHTML = '<span class="text-danger">Ошибка сети при сохранении.</span>';
                }
            });

            deleteBookingBtn.addEventListener('click', async () => {
                if (!activeBookingId) {
                    return;
                }

                if (!confirm('Удалить запись из расписания?')) {
                    return;
                }

                const formData = new FormData();
                formData.append('__RequestVerificationToken', getAntiForgeryToken());
                formData.append('id', activeBookingId);

                try {
                    const response = await fetch('/Schedule/DeleteBooking', {
                        method: 'POST',
                        body: formData
                    });

                    const result = await response.json();
                    if (result.success) {
                        bookingModal.hide();
                        calendar.refetchEvents();
                    } else {
                        modalResult.innerHTML = `<span class="text-danger">${result.message || 'Не удалось удалить запись.'}</span>`;
                    }
                } catch {
                    modalResult.innerHTML = '<span class="text-danger">Ошибка сети при удалении записи.</span>';
                }
            });

            openBookingCardBtn.addEventListener('click', () => {
                if (!activeBookingId) {
                    return;
                }

                const detailsUrl = `/Schedule/Details/${encodeURIComponent(activeBookingId)}`;
                const openDetails = () => {
                    if (window.crmModalHost?.open) {
                        window.crmModalHost.open(detailsUrl, {
                            title: 'Детали записи',
                            iconClass: 'bi bi-eye me-2',
                            size: 'xl',
                            reloadOnComplete: false
                        });
                        return;
                    }

                    window.location.href = detailsUrl;
                };

                bookingModalEl.addEventListener('hidden.bs.modal', openDetails, { once: true });
                bookingModal.hide();
            });

            window.addEventListener('message', event => {
                if (event.origin !== window.location.origin) {
                    return;
                }

                const data = event.data;
                if (!data || typeof data !== 'object' || data.type !== 'crm-booking-details-back') {
                    return;
                }

                const bookingId = String(data.bookingId || '').trim();
                if (!bookingId) {
                    return;
                }

                const reopenBooking = () => {
                    openBookingForEdit(bookingId);
                };

                const globalModalEl = document.getElementById('globalCreateModal');
                if (globalModalEl && globalModalEl.classList.contains('show') && window.crmModalHost?.close) {
                    globalModalEl.addEventListener('hidden.bs.modal', reopenBooking, { once: true });
                    window.crmModalHost.close();
                    return;
                }

                reopenBooking();
            });

            bookingModalEl.addEventListener('hidden.bs.modal', () => {
                isEditMode = false;
                activeBookingId = null;
                createSource = 'calendar';
                modalBookingId.value = '';
                modalResult.innerHTML = '';
                resetSlotAvailabilityState();
                openBookingCardBtn.classList.add('d-none');
            });

            reloadFilterPresets();
        } catch (error) {
            const target = document.getElementById('bookingCalendar');
            if (target) {
                target.innerHTML = '<div class="alert alert-danger mb-0">Ошибка инициализации расписания. Откройте консоль браузера для деталей.</div>';
            }
            console.error(error);
        }
    });
</script>
}

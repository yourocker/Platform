            function validateRequiredFields() {
                clearValidation();
                modalResult.innerHTML = '';

                let hasErrors = false;

                const requiredBase = [modalResourceId, modalPerformerEmployeeId, modalStart, modalEnd];
                requiredBase.forEach(input => {
                    const invalid = !input.value || String(input.value).trim().length === 0;
                    setFieldInvalid(input, invalid);
                    hasErrors = hasErrors || invalid;
                });

                const invalidServices = bookingLineItems.length === 0;
                setFieldInvalid(modalServiceItemIds, invalidServices);
                hasErrors = hasErrors || invalidServices;

                const invalidStatus = !modalStatusId.value || String(modalStatusId.value).trim().length === 0;
                setStatusInvalid(invalidStatus);
                hasErrors = hasErrors || invalidStatus;

                const hasDiscount = bookingLineItems.some(line => Number(line.discountPercent || 0) > 0);
                if (hasDiscount) {
                    const invalidDiscountReason = !modalDiscountReason.value || String(modalDiscountReason.value).trim().length === 0;
                    modalDiscountReason.classList.toggle('is-invalid', invalidDiscountReason);
                    hasErrors = hasErrors || invalidDiscountReason;
                } else {
                    modalDiscountReason.classList.remove('is-invalid');
                }

                if (!hasErrors) {
                    const startValue = parseDate(modalStart.value);
                    const endValue = parseDate(modalEnd.value);
                    if (!startValue || !endValue || startValue >= endValue) {
                        setFieldInvalid(modalStart, true);
                        setFieldInvalid(modalEnd, true);
                        modalResult.innerHTML = '<span class="text-danger">Время окончания должно быть позже времени начала.</span>';
                        return false;
                    }
                }

                if (bookingDynamicFieldManager && !bookingDynamicFieldManager.validate()) {
                    hasErrors = true;
                }

                if (hasErrors && modalResult.innerHTML.length === 0) {
                    modalResult.innerHTML = '<span class="text-danger">Заполните обязательные поля, они выделены красным.</span>';
                }

                if (!hasErrors && slotAvailabilityState.checked && !slotAvailabilityState.canSave) {
                    return false;
                }

                return !hasErrors;
            }


            async function submitBookingTimeChange(eventApi, revert) {
                const bookingId = String(eventApi?.id || '').trim();
                if (!bookingId) {
                    if (typeof revert === 'function') {
                        revert();
                    }
                    return;
                }

                const formatDateForSubmit = value => {
                    if (!(value instanceof Date) || Number.isNaN(value.getTime())) {
                        return '';
                    }

                    const year = value.getFullYear();
                    const month = String(value.getMonth() + 1).padStart(2, '0');
                    const day = String(value.getDate()).padStart(2, '0');
                    const hours = String(value.getHours()).padStart(2, '0');
                    const minutes = String(value.getMinutes()).padStart(2, '0');
                    const seconds = String(value.getSeconds()).padStart(2, '0');
                    return `${year}-${month}-${day}T${hours}:${minutes}:${seconds}`;
                };

                const submit = async allowOutOfHours => {
                    const formData = new FormData();
                    formData.append('__RequestVerificationToken', getAntiForgeryToken());
                    formData.append('bookingId', bookingId);
                    formData.append('start', formatDateForSubmit(eventApi.start));
                    formData.append('end', formatDateForSubmit(eventApi.end));
                    formData.append('allowOutOfHours', allowOutOfHours ? 'true' : 'false');

                    const response = await fetch('/Schedule/RescheduleBooking', {
                        method: 'POST',
                        body: formData
                    });

                    return response.json();
                };

                try {
                    let result = await submit(false);

                    const needsOutOfHoursConfirmation = !result.success &&
                        String(result.message || '').toLowerCase().includes('подтвердите') &&
                        String(result.message || '').toLowerCase().includes('вне рабочего времени');

                    if (needsOutOfHoursConfirmation) {
                        const accepted = confirm('Время записи выходит за рамки рабочего графика компании. Сохранить такую запись?');
                        if (!accepted) {
                            if (typeof revert === 'function') {
                                revert();
                            }
                            return;
                        }

                        result = await submit(true);
                    }

                    if (!result.success) {
                        if (typeof revert === 'function') {
                            revert();
                        }
                        alert(result.message || 'Не удалось изменить время записи.');
                        return;
                    }

                    if (result.start) {
                        eventApi.setStart(result.start);
                    }

                    if (result.end) {
                        eventApi.setEnd(result.end);
                    }

                    calendar.refetchEvents();
                } catch {
                    if (typeof revert === 'function') {
                        revert();
                    }
                    alert('Ошибка сети при изменении времени записи.');
                }
            }


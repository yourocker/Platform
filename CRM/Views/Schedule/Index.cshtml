            function applySelectedServices(services, fallbackServiceId) {
                clearBookingLines();

                (services || []).forEach(service => {
                    const serviceId = String(service.serviceItemId || '');
                    if (!serviceId) {
                        return;
                    }

                    const qty = Number(service.quantity || 1);
                    const discount = Number(service.discountAmount || 0);
                    const customUnitPrice = Number(service.customUnitPrice);
                    appendBookingLine(
                        serviceId,
                        qty > 0 ? Math.round(qty) : 1,
                        discount > 0 ? discount : 0,
                        Number.isFinite(customUnitPrice) && customUnitPrice >= 0 ? customUnitPrice : null);
                });

                if (!bookingLineItems.length && fallbackServiceId) {
                    const fallbackId = String(fallbackServiceId);
                    if (servicesMap.has(fallbackId)) {
                        appendBookingLine(fallbackId, 1, 0, null);

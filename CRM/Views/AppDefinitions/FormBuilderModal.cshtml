@using Core.Entities.Platform.Form
@using CRM.ViewModels.FormConfig
@using System.Text.Json
@using System.Collections.Generic
@model FormBuilderViewModel

<div class="modal fade" id="builderModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-app-id="@Model.AppDefinitionId">
    <div class="modal-dialog modal-xl modal-dialog-centered" style="width: 90vw; max-width: 90vw; height: 90vh; margin: 5vh auto;">
        <div class="modal-content border-0 shadow-lg" style="height: 90vh; background-color: var(--main-bg);">
            
            <div class="modal-header border-bottom px-4 py-2 bg-white">
                <div class="d-flex align-items-center w-100">
                    <div class="me-auto">
                        <h4 class="mb-0 fw-bold" style="color: var(--primary-color);">
                            <i class="bi bi-ui-checks-grid me-2"></i> @Model.AppDefinitionName
                        </h4>
                        <small class="text-muted">Конструктор макетов (@Model.EntityCode)</small>
                    </div>

                    <div class="d-flex align-items-center gap-2 me-4">
                        <div class="input-group input-group-sm" style="width: 340px;">
                            <span class="input-group-text">Форма</span>
                            <select id="formSelector" class="form-select" onchange="formBuilder.switchForm(this.value)"></select>
                            <button class="btn btn-outline-primary" type="button" onclick="formBuilder.openCreateFormModal()" title="Новая форма">
                                <i class="bi bi-plus"></i>
                            </button>
                            <button class="btn btn-outline-secondary" type="button" onclick="formBuilder.openRenameFormModal()" id="renameFormBtn" title="Переименовать">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger" type="button" onclick="formBuilder.deleteCurrentForm()" id="deleteFormBtn" title="Удалить форму">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="setDefaultBtn" onclick="formBuilder.setDefaultCurrentForm()">Сделать основной</button>
                        <div class="btn-group btn-group-sm">
                            <input type="radio" class="btn-check" name="formMode" id="modeCreate" value="Create" checked onchange="formBuilder.switchMode('Create')">
                            <label class="btn btn-outline-primary" for="modeCreate">Создание</label>
                            <input type="radio" class="btn-check" name="formMode" id="modeEdit" value="Edit" onchange="formBuilder.switchMode('Edit')">
                            <label class="btn btn-outline-primary" for="modeEdit">Редакт.</label>
                            <input type="radio" class="btn-check" name="formMode" id="modeView" value="View" onchange="formBuilder.switchMode('View')">
                            <label class="btn btn-outline-primary" for="modeView">Просмотр</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" crm-button variant="light" data-bs-dismiss="modal">Закрыть</button>
                        <button type="button" crm-button variant="primary" icon="check2-all" onclick="formBuilder.saveCurrentLayout()">
                            Сохранить изменения
                        </button>
                    </div>
                </div>
            </div>

            <div class="modal-body p-0 d-flex overflow-hidden">
                <div class="builder-sidebar border-end d-flex flex-column bg-white" style="width: 320px;">
                    <div class="p-3 bg-light border-bottom">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-bold small text-uppercase" style="color: var(--primary-color);">Поля сущности</span>
                            <button class="btn btn-sm btn-link p-0 text-decoration-none" onclick="fieldManager.openCreateFieldModal()">
                                <i class="bi bi-plus-circle"></i> Создать поле
                            </button>
                        </div>
                        <input type="text" class="form-control form-control-sm" placeholder="Поиск по названию..." onkeyup="fieldManager.filterPalette(this.value)">
                    </div>
                    <div class="flex-grow-1 overflow-auto p-2" id="fieldsPaletteContainer">
                        <div class="mb-3">
                            <label class="small fw-bold text-muted px-2 mb-1">СИСТЕМНЫЕ</label>
                            <div id="systemFieldsList" class="d-grid gap-1"></div>
                        </div>
                        <div>
                            <label class="small fw-bold text-muted px-2 mb-1">ПОЛЬЗОВАТЕЛЬСКИЕ</label>
                            <div id="userFieldsList" class="d-grid gap-1"></div>
                        </div>
                    </div>
                </div>

                <div class="flex-grow-1 p-4 overflow-auto builder-canvas-wrapper">
                    <div id="formCanvas" class="mx-auto bg-white rounded shadow-sm p-4 border" style="max-width: 850px; min-height: 100%;">
                        </div>
                </div>

                <div class="builder-sidebar border-start d-flex flex-column bg-white" style="width: 260px;">
                    <div class="p-3 bg-light border-bottom">
                        <span class="fw-bold small text-uppercase">Элементы разметки</span>
                    </div>
                    <div class="p-3" id="markupPalette">
                        <div class="markup-item p-2 border rounded mb-2 bg-white d-flex align-items-center gap-2" data-type="tabControl" style="cursor: grab;">
                            <i class="bi bi-folder2-open text-info"></i> Вкладки
                        </div>
                        <div class="markup-item p-2 border rounded mb-2 bg-white d-flex align-items-center gap-2" data-type="tab" style="cursor: grab;">
                            <i class="bi bi-file-earmark-text text-primary"></i> Вкладка
                        </div>
                        <div class="markup-item p-2 border rounded mb-2 bg-white d-flex align-items-center gap-2" data-type="group" style="cursor: grab;">
                            <i class="bi bi-collection text-warning"></i> Группа
                        </div>
                        <div class="markup-item p-2 border rounded mb-2 bg-white d-flex align-items-center gap-2" data-type="row" style="cursor: grab;">
                            <i class="bi bi-columns-gap text-success"></i> Сетка (колонки)
                        </div>
                        <div class="markup-item p-2 border rounded mb-2 bg-white d-flex align-items-center gap-2" data-type="column" style="cursor: grab;">
                            <i class="bi bi-layout-sidebar-inset text-secondary"></i> Колонка
                        </div>
                    </div>
                    <div class="p-3 border-top bg-light">
                        <span class="fw-bold small text-uppercase">Настройка узла</span>
                    </div>
                    <div class="p-3 flex-grow-1 overflow-auto" id="nodeSettingsPanel">
                        <div class="text-muted small">Выберите элемент на холсте для настройки.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addFieldModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold">Новое поле</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <form id="createFieldForm">
                    <div crm-card class="p-3 mb-0">
                        <div class="mb-3">
                            <crm-input label="Заголовок поля" name="label" placeholder="Например: Дата договора" required="true" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Тип данных</label>
                            <select name="dataType" class="form-select form-select-sm">
                                <option value="0">Строка</option>
                                <option value="2">Число</option>
                                <option value="4">Дата и время</option>
                                <option value="7">Связь с объектом</option>
                                <option value="8">Файл</option>
                            </select>
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" name="isRequired" id="fieldReq">
                                    <label class="form-check-label small" for="fieldReq">Обязательное</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" name="isArray" id="fieldArr">
                                    <label class="form-check-label small" for="fieldArr">Множественное</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="button" crm-button variant="light" class="flex-grow-1" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" crm-button variant="primary" class="flex-grow-1">Создать поле</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold">Новая форма</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <form id="createFormForm">
                    <div crm-card class="p-3 mb-0">
                        <div class="mb-3">
                            <crm-input label="Название формы" name="name" placeholder="Например: Для менеджеров" required="true" />
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="button" crm-button variant="light" class="flex-grow-1" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" crm-button variant="primary" class="flex-grow-1">Создать</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="renameFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold">Переименование формы</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <form id="renameFormForm">
                    <div crm-card class="p-3 mb-0">
                        <div class="mb-3">
                            <crm-input label="Название формы" name="name" placeholder="Введите название..." required="true" />
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                        <button type="button" crm-button variant="light" class="flex-grow-1" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" crm-button variant="primary" class="flex-grow-1">Сохранить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/sortablejs/Sortable.min.js"></script>

<script type="application/json" id="formBuilderPayload">
@Html.Raw(JsonSerializer.Serialize(new
{
    appId = Model.AppDefinitionId,
    initialMode = "Create",
    forms = (Model.Forms ?? new List<FormBuilderFormDto>()).Select(f => new
    {
        id = f.Id,
        name = f.Name,
        type = f.Type.ToString(),
        isDefault = f.IsDefault,
        layoutJson = f.LayoutJson
    })
}))
</script>

@using System.Collections.Generic
@using System.Linq
@using Core.Entities.CRM
@using CRM.ViewModels.Shared
@model Core.DTOs.CRM.ContactDetailsDto
@{
    ViewData["Title"] = Model.FullName;
    var isModal = ViewBag.IsModal as bool? ?? false;
    if (isModal)
    {
        Layout = "_LayoutModal";
        ViewData["ModalSize"] = "xl";
    }

    var tabsModel = new EntityDetailsTabsViewModel
    {
        MainPartialViewName = "~/Views/Contacts/_DetailsMain.cshtml",
        MainModel = Model,
        AdditionalTabs = new List<EntityDetailsTabDefinition>
        {
            new()
            {
                Key = "events",
                Title = "События",
                PartialViewName = "~/Views/Shared/_EntityTimeline.cshtml",
                Model = ViewBag.TimelineEvents as IEnumerable<CrmEvent> ?? Enumerable.Empty<CrmEvent>()
            }
        }
    };
}

<div class="container-fluid px-4">
    <crm-page-header title="" icon="" subtitle="">
    </crm-page-header>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div crm-card>
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">Просмотр контакта</h5>
                    <div class="text-muted small">Карточка клиента</div>
                </div>
                <div class="card-body p-4">
                    <partial name="_EntityDetailsTabs" model="tabsModel" />
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" asp-route-modal="@(isModal ? "true" : null)" crm-button variant="primary" icon="pencil-square" class="px-5 py-2 fs-6 shadow">
                    Изменить
                </a>
                @if (isModal)
                {
                    <button type="button"
                            crm-button
                            variant="outline-secondary"
                            icon="x-lg"
                            class="px-4 py-2 fs-6 shadow-none"
                            onclick="window.parent.postMessage({ type: 'crm-modal-close' }, window.location.origin)">
                        Закрыть
                    </button>
                }
                else
                {
                    <a asp-action="Index" crm-button variant="outline-secondary" icon="arrow-left" class="px-4 py-2 fs-6 shadow-none">
                        К списку
                    </a>
                }
            </div>

            @* Удаление вынесено под кнопки *@
            <div class="mt-3 d-flex justify-content-between align-items-center px-2 pb-5">
                <div class="text-muted small">ID записи: @Model.Id</div>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="text-danger small text-decoration-none opacity-75">
                    <i class="bi bi-trash me-1"></i> Удалить запись
                </a>
            </div>
        </div>
    </div>
</div>

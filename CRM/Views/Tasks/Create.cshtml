@model Core.Entities.Tasks.EmployeeTask

@{
    ViewData["Title"] = "Новая задача";
    if (CRM.Infrastructure.ModalRequestHelper.IsModalRequest(Context.Request))
    {
        ViewData["ModalSize"] = "xl";
    }
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2"></i>Создание новой задачи</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold">Название задачи</label>
                            <input asp-for="Title" class="form-control form-control-lg" placeholder="Введите название..." />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Описание</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold">Постановщик</label>
                                <input type="text" class="form-control bg-light" value="@ViewBag.CurrentUserName" readonly tabindex="-1" />
                            </div>
                            
                            <div class="col-md-6 mb-4">
                                <label asp-for="AssigneeId" class="form-label fw-bold">Исполнитель</label>
                                <select asp-for="AssigneeId" class="form-select" asp-items="ViewBag.Employees"></select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Deadline" class="form-label fw-bold">Срок выполнения</label>
                            <input asp-for="Deadline" type="datetime-local" class="form-control" />
                        </div>

                        <div class="d-flex justify-content-between pt-4 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                            <button type="submit" class="btn btn-primary px-5 fw-bold">Создать задачу</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

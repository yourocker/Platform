@using System.Collections.Generic
@using System.Linq
@using Core.DTOs.Platform
@using Core.Entities.CRM
@using CRM.ViewModels.Shared
@model GenericObjectDto
@{
    ViewData["Title"] = "Просмотр: " + Model.Name;
    var isModal = ViewBag.IsModal as bool? ?? false;
    if (isModal)
    {
        Layout = "_LayoutModal";
        ViewData["ModalSize"] = "xl";
    }

    var tabsModel = new EntityDetailsTabsViewModel
    {
        MainPartialViewName = "~/Views/GenericObjects/_DetailsMain.cshtml",
        MainModel = Model,
        AdditionalTabs = new List<EntityDetailsTabDefinition>
        {
            new()
            {
                Key = "events",
                Title = "События",
                PartialViewName = "~/Views/Shared/_EntityTimeline.cshtml",
                Model = ViewBag.TimelineEvents as IEnumerable<CrmEvent> ?? Enumerable.Empty<CrmEvent>()
            }
        }
    };
}

<div class="container-fluid px-4">
    <crm-page-header title="" icon="" subtitle=""></crm-page-header>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div crm-card>
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">Просмотр объекта</h5>
                    <div class="text-muted small">Тип: @ViewBag.DefinitionName</div>
                </div>
                <div class="card-body p-4">
                    <partial name="_EntityDetailsTabs" model="tabsModel" />
                </div>
            </div>

            <div class="mt-4 pb-5 d-flex gap-2">
                <a href="/Data/Edit/@Model.Id@(isModal ? "?modal=true" : string.Empty)" crm-button variant="primary" icon="pencil-square" class="px-5 shadow">Редактировать</a>
                @if (isModal)
                {
                    <button type="button"
                            crm-button
                            variant="outline-secondary"
                            icon="x-lg"
                            onclick="window.parent.postMessage({ type: 'crm-modal-close' }, window.location.origin)">
                        Закрыть
                    </button>
                }
                else
                {
                    <a href="/Data/@Model.EntityCode" crm-button variant="outline-secondary">Назад к списку</a>
                }
            </div>
        </div>
    </div>
</div>

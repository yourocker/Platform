@using System
@using Core.Entities
@using Core.Entities.Platform
@using Core.Entities.Platform.Form
@using Core.DTOs.Interfaces
@using System.Text.Json
@using Microsoft.AspNetCore.Html
@model object

@{
    var fields = ViewBag.DynamicFields as List<AppFieldDefinition>;
    var fieldsById = fields?.ToDictionary(f => f.Id) ?? new Dictionary<Guid, AppFieldDefinition>();
    var lookupData = ViewBag.LookupData as Dictionary<string, List<SelectListItem>> ?? new Dictionary<string, List<SelectListItem>>();
    var formLayout = ViewBag.FormLayout as FormLayoutSchema;
    var hasNameInLayout = ViewBag.HasNameInLayout as bool? ?? false;

    var values = new Dictionary<string, object>();
    if (Model is IDynamicValues dynValues && dynValues.DynamicValues != null)
    {
        values = dynValues.DynamicValues;
    }
    else if (Model is IHasDynamicProperties hasProps && !string.IsNullOrWhiteSpace(hasProps.Properties))
    {
        try
        {
            values = JsonSerializer.Deserialize<Dictionary<string, object>>(hasProps.Properties) ?? new Dictionary<string, object>();
        }
        catch
        {
            values = new Dictionary<string, object>();
        }
    }

    var action = ViewContext.RouteData.Values["action"]?.ToString();
    bool isEditMode = action == "Create" || action == "Edit";
    var recordId = Model?.GetType().GetProperty("Id")?.GetValue(Model)?.ToString() ?? "";

    var hasValidLayout = formLayout?.Nodes != null && formLayout.Nodes.Any();

    void RenderFieldBlock(AppFieldDefinition field, bool isReadOnly, bool isRequiredOverride, bool canCreate, bool canView, bool useTopLabel)
    {
        if (string.Equals(field.SystemName, "Name", StringComparison.OrdinalIgnoreCase))
        {
            var nameValue = Model?.GetType().GetProperty("Name")?.GetValue(Model)?.ToString() ?? "";
            var hasNameError = ViewData.ModelState.ContainsKey("Name") && ViewData.ModelState["Name"].Errors.Any();
            var nameShowAsReadOnly = !isEditMode || isReadOnly;
            var nameIsRequired = isRequiredOverride || field.IsRequired;
            
            if (useTopLabel)
            {
                <div class="mb-3">
                    <label class="form-label text-muted fw-bold">
                        @field.Label
                        @if (nameIsRequired && isEditMode && !isReadOnly)
                        {
                            <span class="text-danger">*</span>
                        }
                    </label>

                    @if (!nameShowAsReadOnly)
                    {
                        <input type="text" name="Name" value="@nameValue" class="form-control @(hasNameError ? "is-invalid" : "")" @(nameIsRequired ? "required" : "") />
                    }
                    else
                    {
                        <div class="form-control-plaintext">@(string.IsNullOrEmpty(nameValue) ? "—" : nameValue)</div>
                    }

                    @if (hasNameError && isEditMode)
                    {
                        <div class="text-danger small mt-1">
                            @foreach (var error in ViewData.ModelState["Name"].Errors)
                            {
                                <div><i class="bi bi-exclamation-circle"></i> @error.ErrorMessage</div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="row mb-3 align-items-start">
                    <label class="col-sm-3 col-lg-2 col-form-label text-muted text-sm-end fw-bold">
                        @field.Label
                        @if (nameIsRequired && isEditMode && !isReadOnly)
                        {
                            <span class="text-danger">*</span>
                        }
                    </label>

                    <div class="col-sm-9 col-lg-10">
                        @if (!nameShowAsReadOnly)
                        {
                            <input type="text" name="Name" value="@nameValue" class="form-control @(hasNameError ? "is-invalid" : "")" @(nameIsRequired ? "required" : "") />
                        }
                        else
                        {
                            <div class="form-control-plaintext">@(string.IsNullOrEmpty(nameValue) ? "—" : nameValue)</div>
                        }

                        @if (hasNameError && isEditMode)
                        {
                            <div class="text-danger small mt-1">
                                @foreach (var error in ViewData.ModelState["Name"].Errors)
                                {
                                    <div><i class="bi bi-exclamation-circle"></i> @error.ErrorMessage</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
            return;
        }

        var formKey = $"DynamicProps[{field.SystemName}]";
        var hasError = ViewData.ModelState.ContainsKey(formKey) && ViewData.ModelState[formKey].Errors.Any();

        values.TryGetValue(field.SystemName, out var rawValue);

        var currentValues = new List<string>();

        if (rawValue is JsonElement element)
        {
            if (element.ValueKind == JsonValueKind.Array)
                currentValues = element.EnumerateArray().Select(x => x.ToString()).ToList();
            else
                currentValues.Add(element.ToString());
        }
        else if (rawValue is List<object> listObj)
        {
            currentValues = listObj.Select(x => x?.ToString() ?? "").ToList();
        }
        else if (rawValue is string[] arrStr)
        {
            currentValues = arrStr.ToList();
        }
        else if (rawValue != null)
        {
            currentValues.Add(rawValue.ToString() ?? string.Empty);
        }

        if (!currentValues.Any()) currentValues.Add("");

        var showAsReadOnly = !isEditMode || isReadOnly;
        var isRequired = isRequiredOverride || field.IsRequired;

        if (useTopLabel)
        {
            <div class="mb-3">
                <label class="form-label text-muted fw-bold">
                    @field.Label
                    @if (isRequired && isEditMode && !isReadOnly)
                    {
                        <span class="text-danger">*</span>
                    }
                </label>

                <div id="container_@field.SystemName" class="dynamic-field-container">
                    @for (var valueIndex = 0; valueIndex < currentValues.Count; valueIndex++)
                    {
                        var val = currentValues[valueIndex];
                        var wrapperId = "wrapper_" + Guid.NewGuid().ToString("N");

                        <div class="mb-2 dynamic-field-item" id="@wrapperId" data-dynamic-field-item="@field.SystemName">
                            @if (field.DataType == FieldDataType.File && !string.IsNullOrWhiteSpace(val))
                            {
                                <div class="mb-1 d-flex align-items-center">
                                    <a href="@val" target="_blank" class="text-decoration-none small">
                                        <i class="bi bi-paperclip"></i> Текущий файл: @System.IO.Path.GetFileName(val)
                                    </a>
                                    @if (isEditMode && !showAsReadOnly && !string.IsNullOrEmpty(recordId))
                                    {
                                        <button type="button" class="btn btn-link text-danger p-0 ms-2" title="Удалить файл"
                                                onclick="deleteExistingFile('@recordId', '@ViewBag.EntityCode', '@field.SystemName', '@val', '@wrapperId')">
                                            <i class="bi bi-x-circle-fill"></i>
                                        </button>
                                    }
                                </div>
                            }

                            <div class="dynamic-field-control">
                                @if (!showAsReadOnly)
                                {
                                    @renderField(field, val, hasError, lookupData, isRequired)

                                    @if (field.DataType == FieldDataType.EntityLink && canCreate && !string.IsNullOrEmpty(field.TargetEntityCode))
                                    {
                                        <a href="/Data/@field.TargetEntityCode/Create" class="btn btn-outline-secondary ms-2" title="Создать связанный объект">
                                            <i class="bi bi-plus-lg"></i>
                                        </a>
                                    }

                                    @if (field.IsArray)
                                    {
                                        <button type="button"
                                                class="btn btn-outline-danger dynamic-field-remove @(valueIndex == 0 ? "d-none" : string.Empty)"
                                                data-dynamic-field-remove="@field.SystemName"
                                                onclick="removeDynamicFieldItem(this, '@field.SystemName')">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    }
                                }
                                else
                                {
                                    @if (field.DataType == FieldDataType.EntityLink || field.DataType == FieldDataType.Select)
                                    {
                                        var displayName = val;
                                        if (lookupData.ContainsKey(field.SystemName))
                                        {
                                            var found = lookupData[field.SystemName].FirstOrDefault(x => x.Value == val);
                                            if (found != null) displayName = found.Text;
                                        }

                                        if (!string.IsNullOrEmpty(val))
                                        {
                                            if (field.DataType == FieldDataType.EntityLink && canView && !string.IsNullOrEmpty(field.TargetEntityCode))
                                            {
                                                var href = $"/Data/Details/{val}";
                                                <a href="@href" class="btn btn-outline-primary btn-sm">
                                                    <i class="bi bi-link-45deg"></i> @displayName
                                                </a>
                                            }
                                            else
                                            {
                                                <div class="form-control-plaintext">@displayName</div>
                                            }
                                        }
                                        else { <span class="text-muted small">Не указано</span> }
                                    }
                                    else if (field.DataType == FieldDataType.Boolean)
                                    {
                                        var isTrue = (val ?? "").ToLower() == "true";
                                        <div class="form-control-plaintext">
                                            <i class="bi @(isTrue ? "bi-check-circle-fill text-success" : "bi-circle text-muted")"></i>
                                            @(isTrue ? "Да" : "Нет")
                                        </div>
                                    }
                                    else if (field.DataType == FieldDataType.File)
                                    {
                                        if (!string.IsNullOrEmpty(val))
                                        {
                                            <a href="@val" target="_blank" class="btn btn-sm btn-light border">
                                                <i class="bi bi-file-earmark"></i> Скачать
                                            </a>
                                        }
                                        else { <div class="text-muted">Нет файла</div> }
                                    }
                                    else
                                    {
                                        <div class="form-control-plaintext">@(string.IsNullOrEmpty(val) ? "—" : val)</div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (hasError && isEditMode)
                {
                    <div class="text-danger small mt-1">
                        @foreach (var error in ViewData.ModelState[formKey].Errors)
                        {
                            <div><i class="bi bi-exclamation-circle"></i> @error.ErrorMessage</div>
                        }
                    </div>
                }

                @if (field.IsArray && isEditMode && !isReadOnly)
                {
                    <button type="button" class="btn btn-sm btn-outline-secondary mt-1"
                            onclick="addDynamicField('@field.SystemName', '@field.DataType')">
                        <i class="bi bi-plus-lg"></i> Добавить еще
                    </button>
                }
            </div>
        }
        else
        {
            <div class="row align-items-start dynamic-field-row">
                <label class="col-sm-3 col-lg-2 col-form-label text-muted text-sm-end fw-bold">
                    @field.Label
                    @if (isRequired && isEditMode && !isReadOnly)
                    {
                        <span class="text-danger">*</span>
                    }
                </label>

                <div class="col-sm-9 col-lg-10">
                    <div id="container_@field.SystemName" class="dynamic-field-container">
                        @for (var valueIndex = 0; valueIndex < currentValues.Count; valueIndex++)
                        {
                            var val = currentValues[valueIndex];
                            var wrapperId = "wrapper_" + Guid.NewGuid().ToString("N");

                            <div class="mb-2 dynamic-field-item" id="@wrapperId" data-dynamic-field-item="@field.SystemName">
                                @if (field.DataType == FieldDataType.File && !string.IsNullOrWhiteSpace(val))
                                {
                                    <div class="mb-1 d-flex align-items-center">
                                        <a href="@val" target="_blank" class="text-decoration-none small">
                                            <i class="bi bi-paperclip"></i> Текущий файл: @System.IO.Path.GetFileName(val)
                                        </a>
                                        @if (isEditMode && !showAsReadOnly && !string.IsNullOrEmpty(recordId))
                                        {
                                            <button type="button" class="btn btn-link text-danger p-0 ms-2" title="Удалить файл"
                                                    onclick="deleteExistingFile('@recordId', '@ViewBag.EntityCode', '@field.SystemName', '@val', '@wrapperId')">
                                                <i class="bi bi-x-circle-fill"></i>
                                            </button>
                                        }
                                    </div>
                                }

                                <div class="dynamic-field-control">
                                    @if (!showAsReadOnly)
                                    {
                                        @renderField(field, val, hasError, lookupData, isRequired)

                                        @if (field.DataType == FieldDataType.EntityLink && canCreate && !string.IsNullOrEmpty(field.TargetEntityCode))
                                        {
                                            <a href="/Data/@field.TargetEntityCode/Create" class="btn btn-outline-secondary ms-2" title="Создать связанный объект">
                                                <i class="bi bi-plus-lg"></i>
                                            </a>
                                        }

                                        @if (field.IsArray)
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-danger dynamic-field-remove @(valueIndex == 0 ? "d-none" : string.Empty)"
                                                    data-dynamic-field-remove="@field.SystemName"
                                                    onclick="removeDynamicFieldItem(this, '@field.SystemName')">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        @if (field.DataType == FieldDataType.EntityLink || field.DataType == FieldDataType.Select)
                                        {
                                            var displayName = val;
                                            if (lookupData.ContainsKey(field.SystemName))
                                            {
                                                var found = lookupData[field.SystemName].FirstOrDefault(x => x.Value == val);
                                                if (found != null) displayName = found.Text;
                                            }

                                            if (!string.IsNullOrEmpty(val))
                                            {
                                                if (field.DataType == FieldDataType.EntityLink && canView && !string.IsNullOrEmpty(field.TargetEntityCode))
                                                {
                                                    var href = $"/Data/Details/{val}";
                                                    <a href="@href" class="btn btn-outline-primary btn-sm">
                                                        <i class="bi bi-link-45deg"></i> @displayName
                                                    </a>
                                                }
                                                else
                                                {
                                                    <div class="form-control-plaintext">@displayName</div>
                                                }
                                            }
                                            else { <span class="text-muted small">Не указано</span> }
                                        }
                                        else if (field.DataType == FieldDataType.Boolean)
                                        {
                                            var isTrue = (val ?? "").ToLower() == "true";
                                            <div class="form-control-plaintext">
                                                <i class="bi @(isTrue ? "bi-check-circle-fill text-success" : "bi-circle text-muted")"></i>
                                                @(isTrue ? "Да" : "Нет")
                                            </div>
                                        }
                                        else if (field.DataType == FieldDataType.File)
                                        {
                                            if (!string.IsNullOrEmpty(val))
                                            {
                                                <a href="@val" target="_blank" class="btn btn-sm btn-light border">
                                                    <i class="bi bi-file-earmark"></i> Скачать
                                                </a>
                                            }
                                            else { <div class="text-muted">Нет файла</div> }
                                        }
                                        else
                                        {
                                            <div class="form-control-plaintext">@(string.IsNullOrEmpty(val) ? "—" : val)</div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    @if (hasError && isEditMode)
                    {
                        <div class="text-danger small mt-1">
                            @foreach (var error in ViewData.ModelState[formKey].Errors)
                            {
                                <div><i class="bi bi-exclamation-circle"></i> @error.ErrorMessage</div>
                            }
                        </div>
                    }

                    @if (field.IsArray && isEditMode && !isReadOnly)
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary mt-1"
                                onclick="addDynamicField('@field.SystemName', '@field.DataType')">
                            <i class="bi bi-plus-lg"></i> Добавить еще
                        </button>
                    }
                </div>
            </div>
        }
    }

    void RenderNodes(IEnumerable<LayoutNode> nodes, bool useTopLabel = false)
    {
        foreach (var node in nodes)
        {
            switch (node)
            {
                case FieldNode fieldNode when fieldsById.TryGetValue(fieldNode.FieldId, out var field):
                    RenderFieldBlock(field, fieldNode.IsReadOnly, fieldNode.IsRequiredOverride, fieldNode.CanCreate, fieldNode.CanView, useTopLabel);
                    break;
                case GroupNode groupNode:
                    <div class="card mb-3">
                        <div class="card-header fw-semibold">@(groupNode.Title ?? groupNode.CustomLabel ?? "Группа")</div>
                        <div class="card-body">
                            @{ RenderNodes(groupNode.Children, useTopLabel); }
                        </div>
                    </div>
                    break;
                case TabControlNode tabControlNode:
                    {
                        var tabs = tabControlNode.Tabs ?? new List<TabNode>();
                        var controlId = $"tabctl_{Guid.NewGuid():N}";
                        <div class="mb-3">
                            <ul class="nav nav-tabs" role="tablist">
                                @for (var i = 0; i < tabs.Count; i++)
                                {
                                    var tab = tabs[i];
                                    var tabId = $"{controlId}_tab_{i}";
                                    var isActive = i == 0 ? "active" : "";
                                    var isSelected = i == 0 ? "true" : "false";
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link @isActive" id="@($"{tabId}_btn")" data-bs-toggle="tab" data-bs-target="#@tabId" type="button" role="tab" aria-controls="@tabId" aria-selected="@isSelected">
                                            @(tab.Title ?? tab.CustomLabel ?? "Вкладка")
                                        </button>
                                    </li>
                                }
                            </ul>
                            <div class="tab-content border border-top-0 p-3">
                                @for (var i = 0; i < tabs.Count; i++)
                                {
                                    var tab = tabs[i];
                                    var tabId = $"{controlId}_tab_{i}";
                                    var isActive = i == 0 ? "show active" : "";
                                    <div class="tab-pane fade @isActive" id="@tabId" role="tabpanel" aria-labelledby="@($"{tabId}_btn")">
                                        @{ RenderNodes(tab.Children, useTopLabel); }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    break;
                case RowNode rowNode:
                    {
                        var rowTitle = rowNode.CustomLabel;
                        var hasRowTitle = !string.IsNullOrWhiteSpace(rowTitle);
                        <div class="border-top pt-3 mt-3">
                            @if (hasRowTitle)
                            {
                                <div class="fw-semibold text-muted small mb-2">@rowTitle</div>
                            }
                            <div class="row">
                                @foreach (var column in rowNode.Columns)
                                {
                                    <div class="col-md-@Math.Clamp(column.Width, 1, 12)">
                                        @{ RenderNodes(column.Children, true); }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    break;
                case ColumnNode columnNode:
                    <div class="col-md-@Math.Clamp(columnNode.Width, 1, 12)">
                        @{ RenderNodes(columnNode.Children, true); }
                    </div>
                    break;
            }
        }
    }
}

<link rel="stylesheet" href="~/lib/select2/css/select2.min.css" />
<link rel="stylesheet" href="~/lib/select2-bootstrap-5-theme/select2-bootstrap-5-theme.min.css" />

@if (fields != null && fields.Any())
{
    <div class="container-fluid px-0">
        @if (hasValidLayout)
        {
            RenderNodes(formLayout!.Nodes);
        }
        else
        {
            foreach (var field in fields.OrderBy(f => f.SortOrder))
            {
                if (!hasNameInLayout && string.Equals(field.SystemName, "Name", StringComparison.OrdinalIgnoreCase))
                    continue;
                RenderFieldBlock(field, false, false, true, true, true);
            }
        }
    </div>

    <div id="field_templates" style="display:none;">
        <div data-type="String"><input type="text" class="form-control" /></div>
        <div data-type="Number"><input type="number" step="any" class="form-control" /></div>
        <div data-type="Money"><input type="number" step="0.01" class="form-control" placeholder="0.00" /></div>
        <div data-type="Date"><input type="date" class="form-control" /></div>
        <div data-type="DateTime"><input type="datetime-local" class="form-control" /></div>
        <div data-type="File"><input type="file" class="form-control" /></div>
        <div data-type="Boolean">
            <div class="form-check form-switch mt-2">
                <input type="hidden" value="false" /> <input class="form-check-input" type="checkbox" value="true">
            </div>
        </div>
        <div data-type="EntityLink">
            <select class="form-control select2-entity">
                <option value="">-- Выберите --</option>
            </select>
        </div>
        <div data-type="Select">
            <select class="form-control select2-entity">
                <option value="">-- Выберите --</option>
            </select>
        </div>
        <div data-type="Text"><textarea class="form-control" rows="3"></textarea></div>
    </div>

    <script src="~/lib/select2/js/select2.min.js"></script>
    <script>
        function initSelect2(element) {
            $(element).select2({
                theme: "bootstrap-5",
                width: '100%',
                placeholder: "Поиск...",
                allowClear: true,
                dropdownParent: $(element).closest('.col-sm-10')
            });
        }

        $(document).ready(function() {
            $('.select2-entity').each(function() {
                initSelect2(this);
            });

            document.querySelectorAll('[id^="container_"]').forEach(container => {
                const systemName = container.id.replace('container_', '');
                refreshDynamicFieldRemoveButtons(systemName);
            });
        });

        function refreshDynamicFieldRemoveButtons(systemName) {
            const container = document.getElementById('container_' + systemName);
            if (!container) {
                return;
            }

            const buttons = Array.from(container.querySelectorAll(`[data-dynamic-field-remove="${systemName}"]`));
            buttons.forEach((button, index) => {
                button.classList.toggle('d-none', index === 0);
            });
        }

        function removeDynamicFieldItem(button, systemName) {
            const item = button.closest('.dynamic-field-item');
            if (item) {
                item.remove();
            }

            refreshDynamicFieldRemoveButtons(systemName);
        }

        function addDynamicField(systemName, dataType) {
            const container = document.getElementById('container_' + systemName);
            const template = document.querySelector(`#field_templates [data-type="${dataType}"]`) 
                          || document.querySelector(`#field_templates [data-type="String"]`);

            const wrapper = document.createElement('div');
            wrapper.className = 'mb-2 dynamic-field-item';
            wrapper.dataset.dynamicFieldItem = systemName;

            const content = template.cloneNode(true);
            const input = content.querySelector('input') || content.querySelector('textarea') || content.querySelector('select');
            const contentNode = content.classList.contains('form-check')
                ? content
                : (content.firstElementChild || content);

            if (input) {
                input.name = `DynamicProps[${systemName}]`;
                input.value = "";
            }

            if (dataType === 'Boolean') {
                 const hidden = content.querySelector('input[type="hidden"]');
                 if(hidden) hidden.name = `DynamicProps[${systemName}]`;
            }

            if (dataType === 'EntityLink' || dataType === 'Select') {
                const sourceSelect = document.querySelector(`select[name="DynamicProps[${systemName}]"]`);
                if (sourceSelect && input) {
                    input.innerHTML = sourceSelect.innerHTML;
                    input.value = "";
                }
            }

            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'btn btn-outline-danger dynamic-field-remove';
            btn.dataset.dynamicFieldRemove = systemName;
            btn.innerHTML = '<i class="bi bi-x"></i>';
            btn.onclick = function() { removeDynamicFieldItem(this, systemName); };

            const control = document.createElement('div');
            control.className = 'dynamic-field-control';
            control.appendChild(contentNode);
            control.appendChild(btn);

            wrapper.appendChild(control);

            container.appendChild(wrapper);
            refreshDynamicFieldRemoveButtons(systemName);

            if ((dataType === 'EntityLink' || dataType === 'Select') && input) {
                initSelect2(input);
            }
        }

        function deleteExistingFile(id, entityCode, propName, path, wrapperId) {
            if (!confirm('Удалить этот файл?')) return;

            const formData = new FormData();
            formData.append('id', id);
            formData.append('entityCode', entityCode);
            formData.append('propertyName', propName);
            formData.append('filePath', path);

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

            fetch('/files/delete-property', {
                method: 'POST',
                body: formData,
                headers: { 'RequestVerificationToken': token }
            })
            .then(r => r.json())
            .then(d => {
                if (d.success) {
                    const el = document.getElementById(wrapperId);
                    const fileLink = el.querySelector('.d-flex.align-items-center');
                    if(fileLink) fileLink.remove();
                } else {
                    alert('Ошибка: ' + (d.message || 'Unknown'));
                }
            })
            .catch(e => console.error(e));
        }
    </script>
}

@functions {
    IHtmlContent renderField(AppFieldDefinition field, string value, bool hasError, Dictionary<string, List<SelectListItem>> lookupData, bool isRequired)
    {
        var fieldName = $"DynamicProps[{field.SystemName}]";
        var required = (isRequired && !field.IsArray) ? "required" : "";
        var errorClass = hasError ? "is-invalid" : "";

        switch (field.DataType)
        {
            case FieldDataType.EntityLink:
            case FieldDataType.Select:
                var options = new System.Text.StringBuilder();
                options.Append("<option value=\"\">-- Выберите --</option>");
                if (lookupData.TryGetValue(field.SystemName, out var items))
                {
                    foreach (var item in items)
                    {
                        var sel = item.Value == value ? "selected" : "";
                        options.Append($"<option value=\"{item.Value}\" {sel}>{item.Text}</option>");
                    }
                }

                if (!string.IsNullOrWhiteSpace(value) && (items == null || items.All(item => item.Value != value)))
                {
                    options.Append($"<option value=\"{value}\" selected>{value}</option>");
                }

                return new HtmlString($"<select name=\"{fieldName}\" class=\"form-control select2-entity {errorClass}\" {required}>{options}</select>");

            case FieldDataType.Number:
                return new HtmlString($"<input type=\"number\" step=\"any\" name=\"{fieldName}\" value=\"{valForInput(value)}\" class=\"form-control {errorClass}\" {required} />");
            case FieldDataType.Money:
                return new HtmlString($"<input type=\"number\" step=\"0.01\" name=\"{fieldName}\" value=\"{valForInput(value)}\" class=\"form-control {errorClass}\" placeholder=\"0.00\" {required} />");
            case FieldDataType.Date:
                return new HtmlString($"<input type=\"date\" name=\"{fieldName}\" value=\"{valForDate(value)}\" class=\"form-control {errorClass}\" {required} />");
            case FieldDataType.DateTime:
                return new HtmlString($"<input type=\"datetime-local\" name=\"{fieldName}\" value=\"{valForDate(value, true)}\" class=\"form-control {errorClass}\" {required} />");
            case FieldDataType.File:
                return new HtmlString($"<input type=\"file\" name=\"{fieldName}\" class=\"form-control {errorClass}\" {required} />");
            case FieldDataType.Boolean:
                var checkedAttr = (value ?? "").ToLower() == "true" ? "checked" : "";
                return new HtmlString($@"
                    <div class=""form-check form-switch mt-2"">
                        <input type=""hidden"" name=""{fieldName}"" value=""false"" />
                        <input class=""form-check-input"" type=""checkbox"" name=""{fieldName}"" value=""true"" {checkedAttr} />
                        <label class=""form-check-label"">Да</label>
                    </div>");
            case FieldDataType.Text:
                return new HtmlString($"<textarea name=\"{fieldName}\" class=\"form-control {errorClass}\" rows=\"3\" {required}>{value}</textarea>");
            default:
                return new HtmlString($"<input type=\"text\" name=\"{fieldName}\" value=\"{value}\" class=\"form-control {errorClass}\" {required} />");
        }
    }

    string? valForInput(string val) => val?.Replace(",", ".");
    string valForDate(string val, bool isDateTime = false)
    {
        if (DateTime.TryParse(val, out DateTime dt)) return dt.ToString(isDateTime ? "yyyy-MM-ddTHH:mm" : "yyyy-MM-dd");
        return "";
    }
}

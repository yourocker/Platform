@using System.Collections.Generic
@using CRM.ViewModels.Shared
@model EntityDetailsTabsViewModel

@{
    var controlId = $"entity_tabs_{Guid.NewGuid():N}";
    var additionalTabs = Model.AdditionalTabs ?? new List<EntityDetailsTabDefinition>();
}

<div class="entity-details-tabs">
    <ul class="nav nav-tabs" id="@($"{controlId}_nav")" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active"
                    id="@($"{controlId}_main_tab")"
                    data-bs-toggle="tab"
                    data-bs-target="#@($"{controlId}_main")"
                    type="button"
                    role="tab"
                    aria-controls="@($"{controlId}_main")"
                    aria-selected="true">
                @Model.MainTabTitle
            </button>
        </li>
        @foreach (var tab in additionalTabs)
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link"
                        id="@($"{controlId}_{tab.Key}_tab")"
                        data-bs-toggle="tab"
                        data-bs-target="#@($"{controlId}_{tab.Key}")"
                        type="button"
                        role="tab"
                        aria-controls="@($"{controlId}_{tab.Key}")"
                        aria-selected="false">
                    @tab.Title
                </button>
            </li>
        }
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active"
             id="@($"{controlId}_main")"
             role="tabpanel"
             aria-labelledby="@($"{controlId}_main_tab")">
            <partial name="@Model.MainPartialViewName" model="@Model.MainModel" />
        </div>

        @foreach (var tab in additionalTabs)
        {
            <div class="tab-pane fade"
                 id="@($"{controlId}_{tab.Key}")"
                 role="tabpanel"
                 aria-labelledby="@($"{controlId}_{tab.Key}_tab")">
                <partial name="@tab.PartialViewName" model="@tab.Model" />
            </div>
        }
    </div>
</div>

<style>
    .entity-details-tabs .nav-tabs {
        gap: 22px;
        border-bottom: 1px solid rgba(15, 23, 42, 0.08);
        flex-wrap: nowrap;
        overflow-x: auto;
        white-space: nowrap;
        padding: 0 2px;
    }

    .entity-details-tabs .nav-link {
        border: 0;
        border-bottom: 2px solid transparent;
        border-radius: 0;
        color: #475569;
        font-weight: 600;
        padding: 12px 2px 13px;
        background: transparent;
    }

    .entity-details-tabs .nav-link.active,
    .entity-details-tabs .nav-link:hover {
        color: #0f172a;
        border-bottom-color: var(--primary-color, #3b82f6);
        background: transparent;
    }

    .entity-details-tabs .tab-content {
        padding-top: 18px;
    }
</style>

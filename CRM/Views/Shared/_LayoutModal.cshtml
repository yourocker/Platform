@using Core.Services
@inject ICrmStyleService StyleService

@{
    var ui = StyleService.GetSettings();
    var modalSize = (ViewData["ModalSize"] as string) ?? "lg";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Звено CRM</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/select2/css/select2.min.css" />
    <link rel="stylesheet" href="~/lib/select2-bootstrap-5-theme/select2-bootstrap-5-theme.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --primary-color: @ui.PrimaryColor;
            --primary-text: @ui.PrimaryContentColor;
            --accent: @ui.AccentColor;
            --main-bg: @ui.MainBgColor;
            --menu-text: @ui.MenuTextColor;
            --sub-bg: @ui.SubMenuBgColor;
            --sub-text: @ui.SubMenuTextColor;
            --page-bg: @ui.PageBgColor;
            --page-text: @ui.PageTextColor;
            --card-bg: @ui.CardBgColor;
            --card-text: @ui.CardTextColor;
            --base-font-size: @(ui.BaseFontSize)px;
        }

        body {
            margin: 0;
            padding: 0;
            background: transparent;
            color: var(--page-text);
            font-family: 'Segoe UI', sans-serif;
            font-size: var(--base-font-size);
            overflow-x: hidden;
            overflow-y: auto;
            min-height: 0;
        }

        .card {
            background-color: var(--card-bg) !important;
            color: var(--card-text) !important;
            border-color: rgba(0, 0, 0, 0.1);
        }

        .btn-primary {
            background-color: var(--primary-color) !important;
            border-color: var(--primary-color) !important;
            color: var(--primary-text) !important;
        }

        .crm-entity-modal-dialog {
            --crm-modal-dialog-width: 1100px;
            position: relative;
            width: min(var(--crm-modal-dialog-width), calc(100vw - 2rem));
            max-width: min(var(--crm-modal-dialog-width), calc(100vw - 2rem));
        }

        .crm-entity-modal {
            padding-right: 0 !important;
        }

        .crm-entity-modal-content {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            background: #fff;
        }

        .crm-entity-modal-floating-close {
            position: absolute;
            top: 18px;
            left: -64px;
            z-index: 6;
            margin: 0;
            padding: 0.7rem;
            pointer-events: auto;
            border-radius: 999px;
            background-color: rgba(255, 255, 255, 0.96);
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.12);
            opacity: 1;
        }

        .crm-entity-modal-frame {
            display: block;
            background: transparent;
        }

        .crm-entity-modal-dialog[data-crm-modal-size="workspace"] {
            --crm-modal-dialog-width: 1880px;
            margin: 0 0 0 auto;
            height: 100vh;
            width: min(var(--crm-modal-dialog-width), calc(100vw - 52px));
            max-width: min(var(--crm-modal-dialog-width), calc(100vw - 52px));
        }

        .modal.fade .crm-entity-modal-dialog[data-crm-modal-size="workspace"] {
            transform: translateX(64px);
        }

        .modal.show .crm-entity-modal-dialog[data-crm-modal-size="workspace"] {
            transform: translateX(0);
        }

        .crm-entity-modal-dialog[data-crm-modal-size="workspace"] .crm-entity-modal-content {
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border-radius: 0;
            background: linear-gradient(180deg, #f8fbff 0%, #f3f6fb 100%);
            border-left: 1px solid rgba(148, 163, 184, 0.16);
        }

        .crm-entity-modal-dialog[data-crm-modal-size="workspace"] .modal-body {
            flex: 1 1 auto;
            min-height: 0;
            padding: 0;
            overflow: hidden;
        }

        .crm-entity-modal-dialog[data-crm-modal-size="workspace"] .crm-entity-modal-frame {
            height: 100%;
            min-height: 100%;
            background: #f4f7fb;
        }

        @@media (max-width: 991.98px) {
            .crm-entity-modal-dialog[data-crm-modal-size="workspace"] {
                width: 100vw;
                max-width: 100vw;
            }

            .crm-entity-modal-dialog[data-crm-modal-size="workspace"] .crm-entity-modal-content {
                border-left: 0;
            }

            .crm-entity-modal-floating-close {
                top: 12px;
                left: 12px;
            }
        }

        body[data-crm-modal-page="true"] {
            --card-bg: #ffffff;
            --card-text: var(--page-text);
            --page-bg: transparent;
        }

        body[data-crm-modal-page="true"][data-crm-modal-size="workspace"] {
            --page-bg: #f4f7fb;
            background:
                radial-gradient(circle at top left, rgba(96, 165, 250, 0.12), transparent 30%),
                linear-gradient(180deg, #f8fbff 0%, #f4f7fb 100%);
        }

        body[data-crm-modal-page="true"] .crm-page-header {
            display: none !important;
        }

        body[data-crm-modal-page="true"] .container,
        body[data-crm-modal-page="true"] .container-fluid {
            max-width: none !important;
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        body[data-crm-modal-page="true"] > main > .container-fluid > .row,
        body[data-crm-modal-page="true"] > main > .container > .row,
        body[data-crm-modal-page="true"] > main > .container-fluid > form > .row,
        body[data-crm-modal-page="true"] > main > .container > form > .row,
        body[data-crm-modal-page="true"] > main > form > .row {
            margin-left: 0;
            margin-right: 0;
        }

        body[data-crm-modal-page="true"] > main > .container-fluid > .row > [class*="col-"],
        body[data-crm-modal-page="true"] > main > .container > .row > [class*="col-"],
        body[data-crm-modal-page="true"] > main > .container-fluid > form > .row > [class*="col-"],
        body[data-crm-modal-page="true"] > main > .container > form > .row > [class*="col-"],
        body[data-crm-modal-page="true"] > main > form > .row > [class*="col-"] {
            flex: 0 0 100%;
            max-width: 100%;
            padding-left: 0;
            padding-right: 0;
        }

        body[data-crm-modal-page="true"] .card {
            background: #fff !important;
            color: var(--page-text) !important;
            border: 1px solid rgba(15, 23, 42, 0.08) !important;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05) !important;
            border-radius: 16px !important;
            margin-bottom: 14px !important;
        }

        body[data-crm-modal-page="true"] .card-header {
            background: transparent !important;
            border-bottom: 1px solid rgba(15, 23, 42, 0.06) !important;
        }

        body[data-crm-modal-page="true"] .entity-details-tabs,
        body[data-crm-modal-page="true"] .tab-content,
        body[data-crm-modal-page="true"] form,
        body[data-crm-modal-page="true"] .card {
            width: 100%;
        }

        body[data-crm-modal-page="true"] > main > .container-fluid > .row > [class*="col-"] > form > .card:first-of-type > .card-header,
        body[data-crm-modal-page="true"] > main > .container > .row > [class*="col-"] > form > .card:first-of-type > .card-header,
        body[data-crm-modal-page="true"] > main > .container-fluid > .row > [class*="col-"] > .card:first-of-type > .card-header,
        body[data-crm-modal-page="true"] > main > .container > .row > [class*="col-"] > .card:first-of-type > .card-header,
        body[data-crm-modal-page="true"] .container-fluid > form > .card:first-of-type > .card-header,
        body[data-crm-modal-page="true"] .container > form > .card:first-of-type > .card-header,
        body[data-crm-modal-page="true"] .container-fluid > .card:first-of-type > .card-header,
        body[data-crm-modal-page="true"] .container > .card:first-of-type > .card-header,
        body[data-crm-modal-page="true"] main > form > .card:first-of-type > .card-header,
        body[data-crm-modal-page="true"] main > .card:first-of-type > .card-header {
            display: none !important;
        }

        body[data-crm-modal-page="true"] .mt-4.pb-5,
        body[data-crm-modal-page="true"] .pb-5 {
            padding-bottom: 0 !important;
        }

        body[data-crm-modal-page="true"] .tab-content {
            background: #fff;
        }

        body[data-crm-modal-page="true"] .modal-page-debug {
            display: none;
        }

        body[data-crm-modal-page="true"] main[role="main"] {
            padding: 18px 20px 20px;
        }

        body[data-crm-modal-page="true"][data-crm-modal-size="workspace"] main[role="main"] {
            padding: 0;
        }
    </style>
</head>
<body data-crm-modal-page="true" data-crm-modal-size="@modalSize">
    <main role="main">
        @RenderBody()
    </main>

    <div class="modal fade crm-entity-modal" id="globalCreateModal" tabindex="-1" aria-hidden="true" aria-labelledby="globalCreateModalTitle" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-scrollable crm-entity-modal-dialog" id="globalCreateModalDialog">
            <button type="button" class="btn-close crm-entity-modal-floating-close" data-bs-dismiss="modal" aria-label="Close"></button>
            <div class="modal-content border-0 shadow crm-entity-modal-content">
                <h5 class="modal-title visually-hidden" id="globalCreateModalTitle">
                    <i class="bi bi-window me-2"></i> Форма
                </h5>
                <div class="modal-body p-0">
                    <iframe id="globalCreateModalFrame"
                            title="Форма"
                            class="w-100 border-0 crm-entity-modal-frame"
                            style="height: 520px;"></iframe>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/select2/js/select2.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/sortablejs/Sortable.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/crm-modal.js" asp-append-version="true"></script>
    <script src="~/js/crm-searchable-select.js" asp-append-version="true"></script>
    <script src="~/js/crm-related-contacts.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        window.crmSearchableSelect?.initSearchableSelects(document);
    </script>
</body>
</html>

@using Core.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Antiforgery
@using Core.Entities.Company
@using Core.Entities.System
@using Core.Services
@using Core.MultiTenancy

@inject ICrmStyleService StyleService
@inject UserManager<Employee> UserManager
@inject AppDbContext AppDbContext
@inject IAntiforgery Antiforgery

@{
// Загружаем настройки интерфейса через сервис (с кэшированием).
var ui = StyleService.GetSettings();
var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
var currentUser = User.Identity?.IsAuthenticated == true ? await UserManager.GetUserAsync(User) : null;
var currentTenantId = User.FindFirst("tenant_id")?.Value;
var currentTenantName = string.Empty;
var currentTenantRole = User.FindFirst("tenant_role")?.Value ?? User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? string.Empty;
var currentTenantRoleDisplayName = string.IsNullOrWhiteSpace(currentTenantRole)
    ? string.Empty
    : TenantRoleCatalog.GetDisplayName(currentTenantRole);
var tenantMemberships = new List<EmployeeTenantMembership>();
var currentReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

if (currentUser != null)
{
    tenantMemberships = await AppDbContext.EmployeeTenantMemberships
        .IgnoreQueryFilters()
        .AsNoTracking()
        .Include(x => x.Tenant)
        .Where(x => x.EmployeeId == currentUser.Id && x.IsActive && !x.IsDismissed && x.Tenant.IsActive)
        .OrderByDescending(x => x.IsDefault)
        .ThenBy(x => x.Tenant.Name)
        .ToListAsync();

    currentTenantName = tenantMemberships
        .FirstOrDefault(x => x.TenantId.ToString() == currentTenantId)?.Tenant.Name
        ?? tenantMemberships.FirstOrDefault()?.Tenant.Name
        ?? string.Empty;
}
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Звено CRM</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/select2/css/select2.min.css" />
    <link rel="stylesheet" href="~/lib/select2-bootstrap-5-theme/select2-bootstrap-5-theme.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            /* Основные брендовые цвета */
            --primary-color: @ui.PrimaryColor;
            --primary-text: @ui.PrimaryContentColor;
            --accent: @ui.AccentColor;

            /* Узкое меню (Sidebar 1) */
            --main-bg: @ui.MainBgColor;
            --menu-text: @ui.MenuTextColor;

            /* Широкое меню (Sidebar 2 / Sub-menu) */
            --sub-bg: @ui.SubMenuBgColor;
            --sub-text: @ui.SubMenuTextColor;

            /* Рабочая область и текст */
            --page-bg: @ui.PageBgColor;
            --page-text: @ui.PageTextColor;

            /* Карточки, таблицы и блоки данных */
            --card-bg: @ui.CardBgColor;
            --card-text: @ui.CardTextColor;

            --base-font-size: @(ui.BaseFontSize)px;
        }

        body {
            background-color: var(--page-bg);
            color: var(--page-text);
            overflow: hidden;
            height: 100vh;
            display: flex;
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            font-size: var(--base-font-size);
        }

        /* Узкое меню */
        #nav-main {
            width: 70px;
            background: var(--main-bg);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 20px;
            z-index: 1050;
            flex-shrink: 0;
        }

        .nav-logo-container {
            width: 100%;
            display: flex;
            justify-content: center;
            margin-bottom: 20px;
        }
        .nav-logo {
            max-width: 48px;
            max-height: 48px;
            object-fit: contain;
        }

        .main-btn {
            width: 48px; height: 48px;
            display: flex; align-items: center; justify-content: center;
            color: var(--menu-text);
            opacity: 0.7;
            font-size: 1.5rem; margin-bottom: 12px;
            cursor: pointer; border-radius: 10px; transition: 0.2s; text-decoration: none;
        }
        .main-btn:hover { opacity: 1; color: var(--menu-text); background: rgba(255,255,255,0.1); }
        .main-btn.active { color: var(--primary-text); background: var(--primary-color); opacity: 1; }

        /* Вспомогательное меню */
        #nav-sub-shell {
            position: relative;
            width: 240px;
            flex-shrink: 0;
            transition: width 0.22s ease;
            z-index: 1045;
        }

        #nav-sub {
            width: 240px;
            background: var(--sub-bg);
            border-right: 1px solid rgba(0,0,0,0.1);
            display: flex;
            flex-direction: column;
            box-shadow: 2px 0 5px rgba(0,0,0,0.03);
            flex-shrink: 0;
            height: 100vh;
            transition: transform 0.22s ease, opacity 0.22s ease, box-shadow 0.22s ease;
        }

        .sub-header {
            padding: 25px 20px; font-weight: 700; font-size: 1.1rem;
            border-bottom: 1px solid rgba(0,0,0,0.05); height: 60px;
            display: flex; align-items: center; justify-content: space-between; color: var(--sub-text);
            gap: 12px;
        }
        .sub-header span {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .sub-header-toggle,
        .nav-main-toggle {
            border: 0;
            background: transparent;
            color: inherit;
        }
        .sub-header-toggle {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: rgba(0,0,0,0.45);
            transition: background 0.15s ease, color 0.15s ease;
            flex-shrink: 0;
        }
        .sub-header-toggle:hover {
            background: rgba(0,0,0,0.05);
            color: rgba(0,0,0,0.7);
        }
        .sub-link {
            padding: 12px 20px; color: var(--sub-text); text-decoration: none;
            display: flex; align-items: center; transition: 0.15s; opacity: 0.85;
        }
        .sub-link:hover { background: rgba(0,0,0,0.03); color: var(--primary-color); opacity: 1; }
        .sub-link.active { color: var(--primary-color); background: rgba(var(--primary-color), 0.1); font-weight: 600; border-right: 3px solid var(--primary-color); }
        .sub-link i { margin-right: 12px; }

        /* Верхняя панель */
        header.navbar {
            height: 60px;
            background: var(--card-bg);
            color: var(--card-text);
            border-bottom: 1px solid rgba(0,0,0,0.1);
            flex-shrink: 0; padding: 0 20px;
        }

        #main-area { flex-grow: 1; display: flex; flex-direction: column; overflow: hidden; }
        #content-wrapper { flex-grow: 1; overflow-y: auto; padding: 30px; position: relative; }

        #right-sidebar {
            width: 60px; background: var(--card-bg);
            border-left: 1px solid rgba(0,0,0,0.1);
            display: flex; flex-direction: column; align-items: center; flex-shrink: 0; z-index: 1040;
        }

        /* Принудительное применение цветов карточек и таблиц */
        .card { background-color: var(--card-bg) !important; color: var(--card-text) !important; border-color: rgba(0,0,0,0.1); }
        .table { --bs-table-bg: var(--card-bg); --bs-table-color: var(--card-text); color: var(--card-text); border-color: rgba(0,0,0,0.1); }
        .table td, .table th { background-color: var(--card-bg) !important; color: var(--card-text) !important; }

        .text-primary { color: var(--primary-color) !important; }
        .btn-primary {
            background-color: var(--primary-color) !important;
            border-color: var(--primary-color) !important;
            color: var(--primary-text) !important;
        }
        .btn-primary:hover { filter: brightness(90%); }
        .sortable-ghost { opacity: 0.2; }

        .crm-entity-modal-dialog {
            --crm-modal-dialog-width: 1100px;
            position: relative;
            width: min(var(--crm-modal-dialog-width), calc(100vw - 2rem));
            max-width: min(var(--crm-modal-dialog-width), calc(100vw - 2rem));
        }

        .crm-entity-modal {
            padding-right: 0 !important;
        }

        .crm-entity-modal-content {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            background: #fff;
        }

        .crm-entity-modal-floating-close {
            position: absolute;
            top: 18px;
            left: -64px;
            z-index: 6;
            margin: 0;
            padding: 0.7rem;
            pointer-events: auto;
            border-radius: 999px;
            background-color: rgba(255, 255, 255, 0.96);
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.12);
            opacity: 1;
        }

        .crm-entity-modal-floating-close:hover {
            filter: brightness(0.97);
        }

        .crm-entity-modal-frame {
            display: block;
            background: transparent;
        }

        .crm-entity-modal-dialog[data-crm-modal-size="workspace"] {
            --crm-modal-dialog-width: 1880px;
            margin: 0 0 0 auto;
            height: 100vh;
            width: min(var(--crm-modal-dialog-width), calc(100vw - 52px));
            max-width: min(var(--crm-modal-dialog-width), calc(100vw - 52px));
        }

        .modal.fade .crm-entity-modal-dialog[data-crm-modal-size="workspace"] {
            transform: translateX(64px);
        }

        .modal.show .crm-entity-modal-dialog[data-crm-modal-size="workspace"] {
            transform: translateX(0);
        }

        .crm-entity-modal-dialog[data-crm-modal-size="workspace"] .crm-entity-modal-content {
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border-radius: 0;
            background: linear-gradient(180deg, #f8fbff 0%, #f3f6fb 100%);
            border-left: 1px solid rgba(148, 163, 184, 0.16);
        }

        .crm-entity-modal-dialog[data-crm-modal-size="workspace"] .modal-body {
            flex: 1 1 auto;
            min-height: 0;
            padding: 0;
            overflow: hidden;
        }

        .crm-entity-modal-dialog[data-crm-modal-size="workspace"] .crm-entity-modal-frame {
            height: 100%;
            min-height: 100%;
            background: #f4f7fb;
        }

        @@media (max-width: 991.98px) {
            .crm-entity-modal-dialog[data-crm-modal-size="workspace"] {
                width: 100vw;
                max-width: 100vw;
            }

            .crm-entity-modal-dialog[data-crm-modal-size="workspace"] .crm-entity-modal-content {
                border-left: 0;
            }

            .crm-entity-modal-floating-close {
                top: 12px;
                left: 12px;
            }
        }

        #nav-sub-hover-zone {
            display: none;
            position: absolute;
            top: 0;
            left: 100%;
            width: 10px;
            height: 100vh;
        }

        #nav-sub-expand-btn {
            display: none;
            margin-bottom: 18px;
        }

        body.subnav-collapsed #nav-sub-shell {
            width: 0;
            overflow: visible;
        }

        body.subnav-collapsed #nav-sub {
            position: absolute;
            top: 0;
            left: 0;
            opacity: 0;
            pointer-events: none;
            transform: translateX(-18px);
            border-right-color: rgba(0,0,0,0.08);
            background: rgba(255,255,255,0.82);
            backdrop-filter: blur(14px);
            box-shadow: 0 24px 56px rgba(15, 23, 42, 0.18);
        }

        body.subnav-collapsed.subnav-peeking #nav-sub {
            opacity: 1;
            pointer-events: auto;
            transform: translateX(0);
        }

        body.subnav-collapsed #nav-sub-hover-zone {
            display: block;
        }

        body.subnav-collapsed #nav-sub-expand-btn {
            display: flex;
        }

        body.subnav-collapsed .sub-link.active {
            border-right-width: 0;
            box-shadow: inset 3px 0 0 var(--primary-color);
        }
    </style>
</head>
<body>

@* Вызов компонента навигации *@
@await Component.InvokeAsync("Navigation")

<div id="main-area">
    <header class="navbar d-flex align-items-center justify-content-between">
        <div class="d-none d-sm-block">
            <h5 class="m-0 opacity-75">@ViewData["Title"]</h5>
        </div>

        <div class="d-flex align-items-center gap-3">
            <div class="text-end lh-1 d-none d-md-block" id="user-clock-container">
                <div class="fw-bold" id="clock-time" style="font-size: 1.1rem;">00:00</div>
                <small class="opacity-50" id="clock-date" style="font-size: 0.8rem;">Загрузка...</small>
            </div>

            <div class="vr mx-2"></div>

            @if (User.Identity.IsAuthenticated)
            {
            var displayName = currentUser != null ? $"{currentUser.FirstName} {currentUser.LastName}" : User.Identity.Name;
            var timezone = currentUser?.TimezoneId ?? "UTC";

            <input type="hidden" id="notificationAntiforgeryToken" value="@antiforgeryToken" />
            <input type="hidden" id="user-timezone" value="@timezone" />

            <div class="dropdown">
                <button class="btn dropdown-toggle d-flex align-items-center gap-2 border-0 bg-transparent p-0" type="button" data-bs-toggle="dropdown">
                    <div class="text-end lh-sm d-none d-lg-block me-1">
                        @if (!string.IsNullOrWhiteSpace(currentTenantName))
                        {
                            <div class="fw-semibold">@currentTenantName</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(currentTenantRoleDisplayName))
                        {
                            <small class="opacity-50">@currentTenantRoleDisplayName</small>
                        }
                    </div>
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width: 36px; height: 36px; background-color: var(--primary-color); color: var(--primary-text);">
                        @(string.IsNullOrWhiteSpace(displayName) ? "?" : displayName.Substring(0, 1).ToUpper())
                    </div>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="background-color: var(--card-bg); color: var(--card-text);">
                    <li class="px-3 py-2 opacity-50 small">@displayName</li>
                    @if (!string.IsNullOrWhiteSpace(currentTenantName))
                    {
                        <li class="px-3 pb-2 small">
                            <span class="opacity-50">Tenant:</span> @currentTenantName
                        </li>
                    }
                    @if (tenantMemberships.Count > 1)
                    {
                        <li><hr class="dropdown-divider"></li>
                        <li class="px-3 pb-2 pt-1 opacity-50 small">Переключить tenant</li>
                        @foreach (var membership in tenantMemberships)
                        {
                            var isCurrentTenant = membership.TenantId.ToString() == currentTenantId;
                            <li>
                                <form asp-controller="Account" asp-action="SwitchTenant" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="tenantId" value="@membership.TenantId" />
                                    <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                    <button type="submit" class="dropdown-item @(isCurrentTenant ? "active" : "")" style="color: var(--card-text);">
                                        <span>@membership.Tenant.Name</span>
                                        <small class="opacity-50 ms-2">@TenantRoleCatalog.GetDisplayName(membership.RoleCode)</small>
                                    </button>
                                </form>
                            </li>
                        }
                    }
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <button class="dropdown-item" onclick="openProfileSettings()" style="color: var(--card-text);">
                            <i class="bi bi-person-gear me-2"></i> Настройки
                        </button>
                    </li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="dropdown-item text-danger">
                                <i class="bi bi-box-arrow-right me-2"></i> Выйти
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
            }
        </div>
    </header>

    <div id="content-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>
</div>

@* Правая панель *@
<div id="right-sidebar">
    <div class="p-3 text-center border-bottom text-primary position-relative"
         style="height: 60px; display: flex; align-items: center; justify-content: center; cursor: pointer;"
         data-bs-toggle="offcanvas"
         data-bs-target="#notificationSidebar">
        <i class="bi bi-bell-fill fs-5" title="Уведомления"></i>
        <span id="notificationBadge" class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-danger" style="display:none; margin-top: 15px; margin-left: 10px; font-size: 0.6em;">0</span>
    </div>
</div>

@* Модальные окна *@
<div class="modal fade" id="profileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" id="profileModalContent" style="background-color: var(--card-bg); color: var(--card-text);">
            <div class="p-5 text-center">
                <div class="spinner-border text-primary" role="status"></div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade crm-entity-modal" id="globalCreateModal" tabindex="-1" aria-hidden="true" aria-labelledby="globalCreateModalTitle" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-scrollable crm-entity-modal-dialog" id="globalCreateModalDialog">
        <button type="button" class="btn-close crm-entity-modal-floating-close" data-bs-dismiss="modal" aria-label="Close"></button>
        <div class="modal-content border-0 shadow crm-entity-modal-content">
            <h5 class="modal-title visually-hidden" id="globalCreateModalTitle">
                <i class="bi bi-window me-2"></i> Форма
            </h5>
            <div class="modal-body p-0">
                <iframe id="globalCreateModalFrame"
                        title="Форма создания"
                        class="w-100 border-0 crm-entity-modal-frame"
                        style="height: 520px;"></iframe>
            </div>
        </div>
    </div>
</div>

<div class="offcanvas offcanvas-end" tabindex="-1" id="notificationSidebar" style="background-color: var(--card-bg); color: var(--card-text);">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title">Уведомления</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body" id="notificationList">
        <p class="text-center opacity-50 mt-4">Нет новых уведомлений</p>
    </div>
</div>

@* Скрипты *@
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/select2/js/select2.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/lib/sortablejs/Sortable.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/crm-modal.js" asp-append-version="true"></script>
<script src="~/js/crm-searchable-select.js" asp-append-version="true"></script>
<script src="~/js/crm-related-contacts.js" asp-append-version="true"></script>
<script type="module" src="~/js/form-builder/index.js" asp-append-version="true"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.25/signalr.min.js"></script>
<script src="~/js/notifications.js" asp-append-version="true"></script>

<script>
    const subnavStorageKey = 'crm-subnav-collapsed';

    function applySubnavState(collapsed) {
        document.body.classList.toggle('subnav-collapsed', collapsed);
        if (!collapsed) {
            document.body.classList.remove('subnav-peeking');
        }
    }

    function setSubnavCollapsed(collapsed) {
        localStorage.setItem(subnavStorageKey, collapsed ? '1' : '0');
        applySubnavState(collapsed);
    }

    applySubnavState(localStorage.getItem(subnavStorageKey) === '1');

    // Меню
    const el = document.getElementById('sortable-menu');
    if(el) {
        Sortable.create(el, {
            animation: 150,
            ghostClass: 'sortable-ghost',
            store: {
                get: (s) => localStorage.getItem('main-menu-order')?.split('|') || [],
                set: (s) => localStorage.setItem('main-menu-order', s.toArray().join('|'))
            }
        });
    }

    $(document).ready(function() {
        const order = localStorage.getItem('main-menu-order');
        if (order && order.length > 0) {
            const container = $('#sortable-menu');
            order.split('|').forEach(id => {
                const item = container.find(`[data-id="${id}"]`);
                if (item.length) container.append(item);
            });
        }
    });

    // Часы
    function updateClock() {
        const now = new Date();
        const timeString = now.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
        const dateString = now.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' });
        if(document.getElementById('clock-time')) document.getElementById('clock-time').innerText = timeString;
        if(document.getElementById('clock-date')) document.getElementById('clock-date').innerText = dateString;
    }
    setInterval(updateClock, 1000);
    updateClock();

    function openProfileSettings() {
        const modal = new bootstrap.Modal(document.getElementById('profileModal'));
        modal.show();
        $('#profileModalContent').load('/Profile/GetSettings');
    }

    document.addEventListener('DOMContentLoaded', () => {
        const collapseButtons = Array.from(document.querySelectorAll('.sub-header-toggle'));
        const expandButton = document.getElementById('nav-sub-expand-btn');
        const hoverZone = document.getElementById('nav-sub-hover-zone');
        const subnav = document.getElementById('nav-sub');
        let hoverLeaveTimer = null;

        collapseButtons.forEach(button => {
            button.addEventListener('click', () => setSubnavCollapsed(true));
        });

        expandButton?.addEventListener('click', () => setSubnavCollapsed(false));

        const showPeek = () => {
            if (!document.body.classList.contains('subnav-collapsed')) {
                return;
            }

            window.clearTimeout(hoverLeaveTimer);
            document.body.classList.add('subnav-peeking');
        };

        const hidePeek = () => {
            window.clearTimeout(hoverLeaveTimer);
            hoverLeaveTimer = window.setTimeout(() => {
                document.body.classList.remove('subnav-peeking');
            }, 120);
        };

        hoverZone?.addEventListener('mouseenter', showPeek);
        hoverZone?.addEventListener('mouseleave', hidePeek);
        subnav?.addEventListener('mouseenter', showPeek);
        subnav?.addEventListener('mouseleave', hidePeek);
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
<script>
    window.crmSearchableSelect?.initSearchableSelects(document);
</script>
</body>
</html>

@model CRM.Models.NavigationViewModel
@using CRM.Infrastructure.Security
@inject Core.Services.ICrmStyleService StyleService
@inject ITenantPermissionService TenantPermissionService

@{
    var ui = StyleService.GetSettings();
    var canManageTenantSettings = TenantPermissionService.HasPermission(User, TenantPermissions.ManageTenantSettings);
    var canManageTenantMembers = TenantPermissionService.HasPermission(User, TenantPermissions.ManageTenantMembers);
    var canManageConstructors = TenantPermissionService.HasPermission(User, TenantPermissions.ManageConstructors);
    var canManageEmployees = TenantPermissionService.HasPermission(User, TenantPermissions.ManageEmployees);
    var canManageCompanyStructure = TenantPermissionService.HasPermission(User, TenantPermissions.ManageCompanyStructure);
    var canManageServiceCatalog = TenantPermissionService.HasPermission(User, TenantPermissions.ManageServiceCatalog);
    
    // Находим категории для вывода их динамических приложений в системные блоки
    var homeCat = Model.HomeCategory;
    var companyCat = Model.CompanyCategory;
    var scheduleCat = Model.ScheduleCategory;
    var tasksCat = Model.TasksCategory;
    var settingsCat = Model.CustomCategories.FirstOrDefault(c => c.Name == "Конструктор");

    // Определяем активную кастомную категорию (для тех, что созданы полностью вручную)
    var activeCustomCategory = Model.CustomCategories
        .Where(c => !c.IsSystem)
        .FirstOrDefault(c => c.Apps.Any(a => a.EntityCode == Model.EntityCode));
}

<nav id="nav-main">
    @if (!string.IsNullOrEmpty(ui.LogoPath))
    {
        <div class="nav-logo-container">
            <a href="/"><img src="@ui.LogoPath" class="nav-logo" alt="Logo" /></a>
        </div>
    }

    <button type="button" id="nav-sub-expand-btn" class="main-btn nav-main-toggle" title="Развернуть меню" aria-label="Развернуть меню">
        <i class="bi bi-list"></i>
    </button>

    <div id="sortable-menu" style="width: 100%; display: flex; flex-direction: column; align-items: center;">
        <a href="/" class="main-btn @(Model.IsHomeActive ? "active" : "")" data-id="@(homeCat?.Id.ToString() ?? "home")" title="@(homeCat?.Name ?? "Рабочий стол")">
            <i class="bi bi-@(homeCat?.Icon ?? "speedometer2")"></i>
        </a>

        @if (Model.CrmCategory != null && Model.IsCrmModuleEnabled)
        {
            <a href="@Model.CrmDefaultUrl" class="main-btn @(Model.IsCRMActive ? "active" : "")" data-id="@Model.CrmCategory.Id" title="@Model.CrmCategory.Name">
                <i class="bi bi-@Model.CrmCategory.Icon"></i>
            </a>
        }

        <a href="/Employees" class="main-btn @(Model.IsCompanyActive ? "active" : "")" data-id="@(companyCat?.Id.ToString() ?? "company")" title="@(companyCat?.Name ?? "Компания")">
            <i class="bi bi-@(companyCat?.Icon ?? "building")"></i>
        </a>

        @if (Model.IsBookingModuleEnabled)
        {
            <a href="/Schedule" class="main-btn @(Model.IsScheduleActive ? "active" : "")" data-id="@(scheduleCat?.Id.ToString() ?? "schedule")" title="@(scheduleCat?.Name ?? "Расписание")">
                <i class="bi bi-@(scheduleCat?.Icon ?? "calendar2-week")"></i>
            </a>
        }
        
        <a href="/Tasks" class="main-btn @(Model.IsTasksActive ? "active" : "")" data-id="@(tasksCat?.Id.ToString() ?? "tasks")" title="@(tasksCat?.Name ?? "Задачи")">
            <i class="bi bi-@(tasksCat?.Icon ?? "list-check")"></i>
        </a>

        @* Вывод полностью кастомных разделов (Склады, Оборудование и т.д.) *@
        @foreach (var cat in Model.CustomCategories.Where(c => !c.IsSystem))
        {
            var isActive = cat.Apps.Any(a => a.EntityCode == Model.EntityCode);
            <a href="/Data/@cat.Apps.FirstOrDefault()?.EntityCode" class="main-btn @(isActive ? "active" : "")" data-id="@cat.Id" title="@cat.Name">
                <i class="bi bi-@cat.Icon"></i>
            </a>
        }

        @if (canManageConstructors)
        {
            <a href="/AppDefinitions" class="main-btn @(Model.IsSettingsActive ? "active" : "")" data-id="settings" title="Конструктор">
                <i class="bi bi-gear"></i>
            </a>
        }
    </div>
</nav>

<div id="nav-sub-shell">
<nav id="nav-sub">
    @if (Model.IsCrmModuleEnabled && Model.IsCRMActive && Model.CrmCategory != null)
    {
        <div class="sub-header"><span>@Model.CrmCategory.Name</span><button type="button" class="sub-header-toggle" title="Свернуть" aria-label="Свернуть меню"><i class="bi bi-chevron-left"></i></button></div>
        @foreach (var app in Model.CrmApps.OrderBy(a => a.IsSystem ? 0 : 1).ThenBy(a => a.Name))
        {
            var url = app.EntityCode switch
            {
                "Contact" => "/Contacts",
                "Lead" => "/Leads",
                "Deal" => "/Deals",
                _ => $"/Data/{app.EntityCode}"
            };
            var isActive = Model.EntityCode == app.EntityCode ||
                           (app.EntityCode == "Contact" && Model.Controller == "Contacts") ||
                           (app.EntityCode == "Lead" && Model.Controller == "Leads") ||
                           (app.EntityCode == "Deal" && Model.Controller == "Deals");
            <a href="@url" class="sub-link @(isActive ? "active" : "")">
                <i class="bi bi-@app.Icon"></i> @app.Name
            </a>
        }
    }
    else if (Model.IsCompanyActive)
    {
        <div class="sub-header"><span>Компания</span><button type="button" class="sub-header-toggle" title="Свернуть" aria-label="Свернуть меню"><i class="bi bi-chevron-left"></i></button></div>
        @if (canManageCompanyStructure)
        {
            <a href="/Departments" class="sub-link @(Model.Controller == "Departments" ? "active" : "")"><i class="bi bi-diagram-3"></i> Оргструктура</a>
            <a href="/Positions" class="sub-link @(Model.Controller == "Positions" ? "active" : "")"><i class="bi bi-briefcase"></i> Должности</a>
            <a href="/EmployeeSchedule" class="sub-link @(Model.Controller == "EmployeeSchedule" ? "active" : "")"><i class="bi bi-calendar3"></i> График отсутствий</a>
        }
        @if (canManageEmployees)
        {
            <a href="/Employees" class="sub-link @(Model.Controller == "Employees" ? "active" : "")"><i class="bi bi-person-badge"></i> Сотрудники</a>
        }
        @* ДИНАМИЧЕСКИЕ ПРИЛОЖЕНИЯ В КОМПАНИИ *@
        @if (companyCat != null)
        {
            @foreach (var app in companyCat.Apps.Where(a => !a.IsSystem))
            {
                <a href="/Data/@app.EntityCode" class="sub-link @(Model.EntityCode == app.EntityCode ? "active" : "")">
                    <i class="bi bi-@app.Icon"></i> @app.Name
                </a>
            }
        }
        
        @if (canManageTenantSettings || canManageTenantMembers || canManageServiceCatalog)
        {
            <hr />
            <div class="px-3 small text-muted mb-2">Настройки компании</div>
            @if (canManageTenantSettings)
            {
                <a href="/CompanySettings/WorkMode" class="sub-link @(Model.Controller == "CompanySettings" && Model.Action == "WorkMode" ? "active" : "")"><i class="bi bi-clock-history"></i> Режим работы и бронирование</a>
                <a href="/CompanySettings/InterfaceSettings" class="sub-link @(Model.Controller == "CompanySettings" && Model.Action == "InterfaceSettings" ? "active" : "")"><i class="bi bi-palette"></i> Оформление</a>
                <a href="/CompanySettings/Trash" class="sub-link @(Model.Controller == "CompanySettings" && Model.Action == "Trash" ? "active" : "")"><i class="bi bi-trash3"></i> Корзина</a>
            }
            @if (canManageServiceCatalog)
            {
                <a href="/Services" class="sub-link @(Model.Controller == "Services" ? "active" : "")"><i class="bi bi-tag"></i> Справочник услуг</a>
            }
            @if (canManageTenantMembers)
            {
                <a href="/CompanySettings/TenantMembers" class="sub-link @(Model.Controller == "CompanySettings" && Model.Action == "TenantMembers" ? "active" : "")"><i class="bi bi-people"></i> Участники tenant</a>
            }
        }
    }
    else if (Model.IsTasksActive)
    {
        <div class="sub-header"><span>@(tasksCat?.Name ?? "Задачи")</span><button type="button" class="sub-header-toggle" title="Свернуть" aria-label="Свернуть меню"><i class="bi bi-chevron-left"></i></button></div>
        <a href="/Tasks/CreatedByMe" class="sub-link @(Model.Action == "CreatedByMe" ? "active" : "")"><i class="bi bi-person-up"></i> Поставленные мной</a>
        <a href="/Tasks/AssignedToMe" class="sub-link @(Model.Action == "AssignedToMe" ? "active" : "")"><i class="bi bi-person-check"></i> Назначенные мне</a>
        <a href="/Tasks/CompletedTasks" class="sub-link @(Model.Action == "CompletedTasks" ? "active" : "")"><i class="bi bi-check2-all"></i> Выполненные</a>
        @if (tasksCat != null && tasksCat.Apps.Any(a => !a.IsSystem))
        {
            <hr />
            @foreach (var app in tasksCat.Apps.Where(a => !a.IsSystem).OrderBy(a => a.Name))
            {
                <a href="/Data/@app.EntityCode" class="sub-link @(Model.EntityCode == app.EntityCode ? "active" : "")">
                    <i class="bi bi-@app.Icon"></i> @app.Name
                </a>
            }
        }
        <hr />
        <a href="/Tasks" class="sub-link @(Model.Action == "Index" ? "active" : "")"><i class="bi bi-list-ul"></i> Все задачи</a>
    }
    else if (Model.IsScheduleActive)
    {
        <div class="sub-header"><span>@(scheduleCat?.Name ?? "Расписание")</span><button type="button" class="sub-header-toggle" title="Свернуть" aria-label="Свернуть меню"><i class="bi bi-chevron-left"></i></button></div>
        <a href="/Schedule" class="sub-link @(Model.Controller == "Schedule" ? "active" : "")"><i class="bi bi-calendar-week"></i> Календарь</a>
        <a href="/CompanySettings/WorkMode#booking-resources-settings" class="sub-link @(Model.Controller == "CompanySettings" && Model.Action == "WorkMode" ? "active" : "")"><i class="bi bi-sliders"></i> Настройки бронирования</a>
        @if (scheduleCat != null)
        {
            @foreach (var app in scheduleCat.Apps.Where(a => !a.IsSystem).OrderBy(a => a.Name))
            {
                <a href="/Data/@app.EntityCode" class="sub-link @(Model.EntityCode == app.EntityCode ? "active" : "")">
                    <i class="bi bi-@app.Icon"></i> @app.Name
                </a>
            }
        }
    }
    else if (Model.IsSettingsActive)
    {
        <div class="sub-header"><span>Конструктор</span><button type="button" class="sub-header-toggle" title="Свернуть" aria-label="Свернуть меню"><i class="bi bi-chevron-left"></i></button></div>

        @* ДИНАМИЧЕСКИЕ ПРИЛОЖЕНИЯ В КОНСТРУКТОРЕ *@
        @if (settingsCat != null)
        {
            @foreach (var app in settingsCat.Apps.Where(a => !a.IsSystem))
            {
                <a href="/Data/@app.EntityCode" class="sub-link @(Model.EntityCode == app.EntityCode ? "active" : "")">
                    <i class="bi bi-@app.Icon"></i> @app.Name
                </a>
            }
        }

        @if (canManageConstructors)
        {
            <hr />
            <div class="px-3 small text-muted mb-2">Настройки системы</div>
            <a href="/AppDefinitions" class="sub-link @(Model.Controller == "AppDefinitions" ? "active" : "")"><i class="bi bi-layers"></i> Список сущностей</a>
            <a href="/AppCategories" class="sub-link @(Model.Controller == "AppCategories" ? "active" : "")"><i class="bi bi-folder2-open"></i> Разделы меню</a>
        }
    }
    else if (activeCustomCategory != null)
    {
        <div class="sub-header"><span>@activeCustomCategory.Name</span><button type="button" class="sub-header-toggle" title="Свернуть" aria-label="Свернуть меню"><i class="bi bi-chevron-left"></i></button></div>
        @foreach (var app in activeCustomCategory.Apps.OrderBy(a => a.Name))
        {
            <a href="/Data/@app.EntityCode" class="sub-link @(Model.EntityCode == app.EntityCode ? "active" : "")">
                <i class="bi bi-@app.Icon"></i> @app.Name
            </a>
        }
    }
    else if (Model.IsHomeActive)
    {
        <div class="sub-header"><span>@(homeCat?.Name ?? "Рабочий стол")</span><button type="button" class="sub-header-toggle" title="Свернуть" aria-label="Свернуть меню"><i class="bi bi-chevron-left"></i></button></div>
        <a href="/" class="sub-link @(Model.Controller == "Home" ? "active" : "")"><i class="bi bi-house"></i> Рабочий стол</a>
        @if (homeCat != null)
        {
            @foreach (var app in homeCat.Apps.Where(a => !a.IsSystem).OrderBy(a => a.Name))
            {
                <a href="/Data/@app.EntityCode" class="sub-link @(Model.EntityCode == app.EntityCode ? "active" : "")">
                    <i class="bi bi-@app.Icon"></i> @app.Name
                </a>
            }
        }
    }
    else
    {
        <div class="sub-header"><span>Главная</span><button type="button" class="sub-header-toggle" title="Свернуть" aria-label="Свернуть меню"><i class="bi bi-chevron-left"></i></button></div>
        <a href="/" class="sub-link active"><i class="bi bi-house"></i> Рабочий стол</a>
    }
</nav>
<div id="nav-sub-hover-zone" aria-hidden="true"></div>
</div>

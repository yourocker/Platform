@using System.Text.Json
@using Core.Entities.Platform
@using CRM.ViewModels.CRM
@using Microsoft.AspNetCore.Html
@model CRM.ViewModels.CRM.CrmCardLayoutRenderViewModel

@{
    var prefix = ViewBag.CrmCardLayoutPrefix as string ?? "crm-layout";
    var fieldsById = Model.DynamicFields.ToDictionary(field => field.Id);
    var palette = CrmCardLayoutCatalog.BuildPalette(Model.EntityCode, Model.DynamicFields);
    var paletteByIdentity = palette.ToDictionary(item => item.Identity, StringComparer.OrdinalIgnoreCase);
    var visibleIdentities = Model.Layout.Sections
        .SelectMany(section => section.Items)
        .Select(item => item.Identity)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
    var hiddenPaletteItems = palette
        .Where(item => !visibleIdentities.Contains(item.Identity))
        .ToList();
    var contactCreateUrl = ViewBag.ContactCreateUrl as string ?? "/Contacts/Create?modal=true";
    var companyCreateUrl = ViewBag.CompanyCreateUrl as string ?? "/Data/Company/Create?modal=true";
    var dynamicFieldCreateUrls = Model.DynamicFieldCreateUrls ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    var layoutJson = JsonSerializer.Serialize(Model.Layout);
    var paletteJson = JsonSerializer.Serialize(palette.Select(item => new
    {
        identity = item.Identity,
        kind = item.Kind,
        key = item.Key,
        fieldId = item.FieldId,
        label = item.Label,
        isBuiltIn = item.IsBuiltIn
    }).ToList());
    var fieldsJson = JsonSerializer.Serialize(Model.DynamicFields.Select(field => new
    {
        id = field.Id,
        label = field.Label,
        systemName = field.SystemName,
        dataType = field.DataType.ToString(),
        isRequired = field.IsRequired,
        isArray = field.IsArray,
        targetEntityCode = field.TargetEntityCode,
        sortOrder = field.SortOrder,
        selectOptions = field.GetSelectOptions()
            .OrderBy(option => option.SortOrder)
            .Select(option => new
            {
                value = option.Value,
                label = option.Label
            })
            .ToList()
    }).ToList());
    var lookupDataJson = JsonSerializer.Serialize(Model.LookupData.ToDictionary(
        pair => pair.Key,
        pair => pair.Value.Select(item => new
        {
            value = item.Value,
            text = item.Text
        }).ToList(),
        StringComparer.OrdinalIgnoreCase));
    var dynamicFieldCreateUrlsJson = JsonSerializer.Serialize(dynamicFieldCreateUrls);
    var definitionsJson = JsonSerializer.Serialize(Model.AllDefinitions.Select(item => new
    {
        entityCode = item.EntityCode,
        name = item.Name
    }).ToList());

    Dictionary<string, object> values = Model.FormModel.DynamicValues ?? new Dictionary<string, object>();

    List<string> GetCurrentValues(AppFieldDefinition field)
    {
        values.TryGetValue(field.SystemName, out var rawValue);
        var currentValues = new List<string>();

        if (rawValue is JsonElement element)
        {
            if (element.ValueKind == JsonValueKind.Array)
            {
                currentValues = element.EnumerateArray().Select(x => x.ToString()).ToList();
            }
            else
            {
                currentValues.Add(element.ToString());
            }
        }
        else if (rawValue is List<object> listObj)
        {
            currentValues = listObj.Select(x => x?.ToString() ?? string.Empty).ToList();
        }
        else if (rawValue is string[] arrStr)
        {
            currentValues = arrStr.ToList();
        }
        else if (rawValue != null)
        {
            currentValues.Add(rawValue.ToString() ?? string.Empty);
        }

        if (!currentValues.Any())
        {
            currentValues.Add(string.Empty);
        }

        return currentValues;
    }

    string ResolveDynamicFieldCreateUrl(AppFieldDefinition field)
    {
        return dynamicFieldCreateUrls.TryGetValue(field.SystemName, out var url)
            ? url
            : string.Empty;
    }

    string ResolveItemIdentity(string itemKind, string? itemKey, Guid? fieldId)
    {
        return string.Equals(itemKind, "dynamic", StringComparison.OrdinalIgnoreCase) && fieldId.HasValue
            ? $"dynamic:{fieldId.Value:D}"
            : $"system:{itemKey?.Trim().ToLowerInvariant()}";
    }

    string ResolveItemLabel(string itemKind, string? itemKey, Guid? fieldId)
    {
        var identity = ResolveItemIdentity(itemKind, itemKey, fieldId);
        return paletteByIdentity.TryGetValue(identity, out var paletteItem)
            ? paletteItem.Label
            : identity;
    }

    async Task RenderBuilderToolbar(string itemKind, string? itemKey, Guid? fieldId)
    {
        <div class="crm-card-layout-builder-toolbar">
            <span class="crm-card-layout-builder-handle" title="Переместить">
                <i class="bi bi-grip-vertical"></i>
            </span>
            <button type="button"
                    class="btn btn-sm btn-link text-danger p-0"
                    title="Скрыть поле"
                    data-crm-card-layout-remove-item="true"
                    data-item-kind="@itemKind"
                    data-item-key="@itemKey"
                    data-field-id="@(fieldId?.ToString() ?? string.Empty)">
                <i class="bi bi-eye-slash"></i>
            </button>
        </div>
    }

    async Task RenderLayoutItem(CrmCardLayoutItemViewModel item)
    {
        var itemIdentity = ResolveItemIdentity(item.Kind, item.Key, item.FieldId);
        var itemLabel = ResolveItemLabel(item.Kind, item.Key, item.FieldId);

        <div class="crm-card-layout__item"
             data-item-kind="@item.Kind"
             data-item-key="@item.Key"
             data-field-id="@(item.FieldId?.ToString() ?? string.Empty)"
             data-item-identity="@itemIdentity"
             data-item-label="@itemLabel">
            @{
                await RenderBuilderToolbar(item.Kind, item.Key, item.FieldId);
            }

            @if (string.Equals(item.Kind, "dynamic", StringComparison.OrdinalIgnoreCase) &&
                 item.FieldId.HasValue &&
                 fieldsById.TryGetValue(item.FieldId.Value, out var field))
            {
                await RenderDynamicField(field);
            }
            else if (string.Equals(item.Kind, "system", StringComparison.OrdinalIgnoreCase) &&
                     !string.IsNullOrWhiteSpace(item.Key))
            {
                await RenderSystemField(item.Key);
            }
        </div>
    }

    async Task RenderDynamicField(AppFieldDefinition field)
    {
        var currentValues = GetCurrentValues(field);
        var formKey = $"DynamicProps[{field.SystemName}]";
        var hasError = ViewData.ModelState.ContainsKey(formKey) && ViewData.ModelState[formKey]!.Errors.Any();
        var recordId = Model.FormModel.Id.ToString();
        var createUrl = ResolveDynamicFieldCreateUrl(field);

        <div class="crm-card-layout-field">
            <label class="form-label text-muted fw-bold">
                @field.Label
                @if (field.IsRequired)
                {
                    <span class="text-danger">*</span>
                }
            </label>

            <div id="container_@field.SystemName" class="dynamic-field-container">
                @for (var valueIndex = 0; valueIndex < currentValues.Count; valueIndex++)
                {
                    var value = currentValues[valueIndex];
                    var wrapperId = "wrapper_" + Guid.NewGuid().ToString("N");

                    <div class="mb-2 dynamic-field-item" id="@wrapperId" data-dynamic-field-item="@field.SystemName">
                        @if (field.DataType == FieldDataType.File && !string.IsNullOrWhiteSpace(value))
                        {
                            <div class="mb-1 d-flex align-items-center">
                                <a href="@value" target="_blank" class="text-decoration-none small">
                                    <i class="bi bi-paperclip"></i> Текущий файл: @System.IO.Path.GetFileName(value)
                                </a>
                                @if (!string.IsNullOrEmpty(recordId))
                                {
                                    <button type="button"
                                            class="btn btn-link text-danger p-0 ms-2"
                                            title="Удалить файл"
                                            onclick="deleteExistingFile('@recordId', '@Model.EntityCode', '@field.SystemName', '@value', '@wrapperId')">
                                        <i class="bi bi-x-circle-fill"></i>
                                    </button>
                                }
                            </div>
                        }

                        <div class="dynamic-field-control">
                            @RenderDynamicFieldInput(field, value, hasError, Model.LookupData, field.IsRequired)

                            @if (field.DataType == FieldDataType.EntityLink &&
                                 !string.IsNullOrWhiteSpace(field.TargetEntityCode) &&
                                 !string.IsNullOrWhiteSpace(createUrl))
                            {
                                <button type="button"
                                        class="btn btn-outline-secondary ms-2"
                                        title="Создать связанный объект"
                                        data-crm-dynamic-create="true"
                                        data-create-url="@createUrl"
                                        data-target-entity-code="@field.TargetEntityCode"
                                        data-title="@field.Label">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            }

                            @if (field.IsArray)
                            {
                                <button type="button"
                                        class="btn btn-outline-danger dynamic-field-remove @(valueIndex == 0 ? "d-none" : string.Empty)"
                                        data-dynamic-field-remove="@field.SystemName"
                                        onclick="removeDynamicFieldItem(this, '@field.SystemName')">
                                    <i class="bi bi-x"></i>
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>

            @if (hasError)
            {
                <div class="text-danger small mt-1">
                    @foreach (var error in ViewData.ModelState[formKey]!.Errors)
                    {
                        <div><i class="bi bi-exclamation-circle"></i> @error.ErrorMessage</div>
                    }
                </div>
            }

            @if (field.IsArray)
            {
                <button type="button"
                        class="btn btn-sm btn-outline-secondary mt-1"
                        onclick="addDynamicField('@field.SystemName', '@field.DataType')">
                    <i class="bi bi-plus-lg"></i> Добавить еще
                </button>
            }
        </div>
    }

    async Task RenderSystemField(string key)
    {
        switch (key)
        {
            case "Amount":
                <div class="crm-card-layout-field">
                    <label class="form-label text-muted fw-bold">Сумма</label>
                    <input type="text"
                           name="Amount"
                           value="@Model.FormModel.Amount.ToString("0.##")"
                           class="form-control"
                           inputmode="decimal"
                           autocomplete="off" />
                </div>
                break;
            case "Currency":
                <div class="crm-card-layout-field">
                    <label class="form-label text-muted fw-bold">Валюта</label>
                    <input type="text"
                           name="Currency"
                           value="@Model.FormModel.Currency"
                           maxlength="10"
                           class="form-control"
                           autocomplete="off" />
                </div>
                break;
            case "ResponsibleId":
                <div class="crm-card-layout-field">
                    <label class="form-label text-muted fw-bold">Ответственный</label>
                    <select id="@($"{prefix}-responsible")"
                            name="ResponsibleId"
                            class="form-select searchable-select"
                            data-search-placeholder="Поиск сотрудника...">
                        <option value="">Не назначен</option>
                        @foreach (var option in Model.FormModel.ResponsibleOptions)
                        {
                            var selected = Model.FormModel.ResponsibleId.HasValue &&
                                           string.Equals(option.Value, Model.FormModel.ResponsibleId.Value.ToString(), StringComparison.OrdinalIgnoreCase);
                            <option value="@option.Value" selected="@(selected ? "selected" : null)">@option.Text</option>
                        }
                    </select>
                </div>
                break;
            case "CompanyId":
                <div class="crm-card-layout-field">
                    <label class="form-label text-muted fw-bold">Компания</label>
                    <div class="crm-process-link-editor">
                        <select id="@($"{prefix}-company")"
                                name="CompanyId"
                                class="form-select searchable-select"
                                data-search-placeholder="Поиск компании...">
                            <option value="">Не выбрана</option>
                            @foreach (var option in Model.FormModel.CompanyOptions)
                            {
                                var selected = Model.FormModel.CompanyId.HasValue &&
                                               string.Equals(option.Value, Model.FormModel.CompanyId.Value.ToString(), StringComparison.OrdinalIgnoreCase);
                                <option value="@option.Value" selected="@(selected ? "selected" : null)">@option.Text</option>
                            }
                        </select>
                        <button type="button"
                                class="btn btn-outline-secondary"
                                title="Открыть компанию"
                                data-crm-linked-open="true"
                                data-select-id="@($"{prefix}-company")"
                                data-detail-url-template="/Data/Details/__ID__?modal=true"
                                data-open-title="Компания">
                            <i class="bi bi-box-arrow-up-right"></i>
                        </button>
                        <button type="button"
                                class="btn btn-outline-secondary"
                                title="Создать компанию"
                                data-crm-linked-create="true"
                                data-select-id="@($"{prefix}-company")"
                                data-create-url="@companyCreateUrl"
                                data-target-entity-code="Company"
                                data-create-title="Новая компания">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                </div>
                break;
            case "ContactLinks":
                {
                    var contactFieldValues = Model.FormModel.ContactIds
                        .Select(id => id.ToString())
                        .Distinct()
                        .ToList();

                    if (Model.FormModel.ContactId.HasValue)
                    {
                        var primaryContactValue = Model.FormModel.ContactId.Value.ToString();
                        if (!contactFieldValues.Contains(primaryContactValue))
                        {
                            contactFieldValues.Insert(0, primaryContactValue);
                        }
                    }

                    if (!contactFieldValues.Any())
                    {
                        contactFieldValues.Add(string.Empty);
                    }

                    <div class="crm-card-layout-field">
                        <label class="form-label text-muted fw-bold">Контакты</label>
                        <input type="hidden"
                               id="@($"{prefix}-primary-contact-id")"
                               name="ContactId"
                               value="@(Model.FormModel.ContactId?.ToString() ?? string.Empty)" />
                        <div class="crm-process-link-array-field">
                            <div id="@($"{prefix}-contact-links-container")"
                                 class="crm-process-link-array"
                                 data-crm-related-contacts="true"
                                 data-template-id="@($"{prefix}-contact-link-template")"
                                 data-add-button-id="@($"{prefix}-contact-links-add")"
                                 data-primary-input-id="@($"{prefix}-primary-contact-id")"
                                 data-create-url="@contactCreateUrl"
                                 data-create-title="Новый контакт"
                                 data-open-title="Контакт"
                                 data-detail-url-template="/Contacts/Details/__ID__?modal=true"
                                 data-field-name="ContactIds">
                                @foreach (var contactValue in contactFieldValues)
                                {
                                    var isPrimaryRow = Model.FormModel.ContactId.HasValue &&
                                                       string.Equals(contactValue, Model.FormModel.ContactId.Value.ToString(), StringComparison.OrdinalIgnoreCase);
                                    <div class="mb-2 crm-process-related-contact-row"
                                         data-crm-related-contact-row="true"
                                         data-crm-primary="@(isPrimaryRow ? "true" : "false")">
                                        <div class="dynamic-field-control">
                                            <button type="button"
                                                    class="btn btn-outline-secondary crm-process-related-contact-primary"
                                                    title="Сделать основным"
                                                    data-crm-related-contact-primary="true">
                                                <i class="bi @(isPrimaryRow ? "bi-star-fill" : "bi-star")"></i>
                                            </button>
                                            <select class="form-select searchable-select"
                                                    data-crm-related-contact-select="true"
                                                    data-field-name="ContactIds"
                                                    data-search-placeholder="Поиск контакта..."
                                                    name="@(string.IsNullOrWhiteSpace(contactValue) ? null : "ContactIds")">
                                                <option value="">Поиск контакта...</option>
                                                @foreach (var option in Model.FormModel.ContactOptions)
                                                {
                                                    var isSelected = string.Equals(option.Value, contactValue, StringComparison.OrdinalIgnoreCase);
                                                    <option value="@option.Value" selected="@(isSelected ? "selected" : null)">@option.Text</option>
                                                }
                                            </select>
                                            <button type="button"
                                                    class="btn btn-outline-secondary"
                                                    title="Открыть контакт"
                                                    data-crm-related-contact-open="true">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </button>
                                            <button type="button"
                                                    class="btn btn-outline-primary"
                                                    title="Создать контакт"
                                                    data-crm-related-contact-create="true">
                                                <i class="bi bi-plus-lg"></i>
                                            </button>
                                            <button type="button"
                                                    class="btn btn-outline-danger"
                                                    title="Удалить контакт"
                                                    data-crm-related-contact-remove="true">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                            <template id="@($"{prefix}-contact-link-template")">
                                <div class="mb-2 crm-process-related-contact-row"
                                     data-crm-related-contact-row="true"
                                     data-crm-primary="false">
                                    <div class="dynamic-field-control">
                                        <button type="button"
                                                class="btn btn-outline-secondary crm-process-related-contact-primary"
                                                title="Сделать основным"
                                                data-crm-related-contact-primary="true">
                                            <i class="bi bi-star"></i>
                                        </button>
                                        <select class="form-select searchable-select"
                                                data-crm-related-contact-select="true"
                                                data-field-name="ContactIds"
                                                data-search-placeholder="Поиск контакта...">
                                            <option value="">Поиск контакта...</option>
                                            @foreach (var option in Model.FormModel.ContactOptions)
                                            {
                                                <option value="@option.Value">@option.Text</option>
                                            }
                                        </select>
                                        <button type="button"
                                                class="btn btn-outline-secondary"
                                                title="Открыть контакт"
                                                data-crm-related-contact-open="true">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                        </button>
                                        <button type="button"
                                                class="btn btn-outline-primary"
                                                title="Создать контакт"
                                                data-crm-related-contact-create="true">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                        <button type="button"
                                                class="btn btn-outline-danger"
                                                title="Удалить контакт"
                                                data-crm-related-contact-remove="true">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </div>
                            </template>
                            <button type="button"
                                    class="btn btn-sm btn-outline-secondary"
                                    id="@($"{prefix}-contact-links-add")">
                                <i class="bi bi-plus-lg me-1"></i> Добавить еще
                            </button>
                        </div>
                        <div class="form-text">Можно указать несколько контактов. Звёздочка отмечает основной контакт, и основным может быть только один.</div>
                    </div>
                }
                break;
        }
    }
}

<div class="crm-card-layout"
     data-crm-card-layout-root="true"
     data-prefix="@prefix">
    <div class="crm-card-layout__toolbar">
        <button type="button"
                class="btn btn-outline-secondary btn-sm"
                data-crm-card-layout-toggle="true">
            <i class="bi bi-layout-three-columns me-1"></i> Конструктор карточки
        </button>
    </div>

    <div class="crm-card-layout__workspace">
        <div class="crm-card-layout__canvas">
            <div class="crm-card-layout__sections" data-crm-card-layout-sections="true">
                @foreach (var layoutSection in Model.Layout.Sections)
                {
                    <section class="card border-0 shadow-sm mb-3 crm-card-layout__section"
                             data-section-id="@(layoutSection.Id)">
                        <div class="card-body p-4">
                            <div class="crm-card-layout__section-header">
                                <div class="crm-card-layout__section-title">
                                    @layoutSection.Title
                                </div>
                                <div class="crm-card-layout__section-tools">
                                    <button type="button"
                                            class="btn btn-sm btn-link text-secondary p-0"
                                            title="Выбрать раздел"
                                            data-crm-card-layout-select-section="true"
                                            data-section-id="@(layoutSection.Id)">
                                        <i class="bi bi-cursor"></i>
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-link text-secondary p-0"
                                            title="Переименовать раздел"
                                            data-crm-card-layout-rename-section="true"
                                            data-section-id="@(layoutSection.Id)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <span class="crm-card-layout-builder-handle" title="Переместить раздел">
                                        <i class="bi bi-grip-vertical"></i>
                                    </span>
                                    <button type="button"
                                            class="btn btn-sm btn-link text-danger p-0"
                                            title="Удалить раздел"
                                            data-crm-card-layout-remove-section="true"
                                            data-section-id="@(layoutSection.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="crm-card-layout__items"
                                 data-crm-card-layout-items="true"
                                 data-section-id="@(layoutSection.Id)">
                                @foreach (var item in layoutSection.Items)
                                {
                                    await RenderLayoutItem(item);
                                }
                            </div>
                        </div>
                    </section>
                }
            </div>

            <div class="crm-card-layout__stash d-none"
                 data-crm-card-layout-stash="true"
                 aria-hidden="true">
                @foreach (var paletteItem in hiddenPaletteItems)
                {
                    var hiddenItem = new CrmCardLayoutItemViewModel
                    {
                        Kind = paletteItem.Kind,
                        Key = paletteItem.Key,
                        FieldId = paletteItem.FieldId
                    };

                    await RenderLayoutItem(hiddenItem);
                }
            </div>
        </div>

        <aside class="crm-card-layout__builder" data-crm-card-layout-builder="true">
            <div class="crm-card-layout__builder-header">
                <div class="fw-bold">Конструктор карточки</div>
                <div class="small text-muted">Изменения применяются ко всей воронке</div>
            </div>

            <div class="crm-card-layout__builder-actions">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-crm-card-layout-add-section="true">
                    <i class="bi bi-plus-square me-1"></i> Добавить раздел
                </button>
                <button type="button" class="btn btn-outline-primary btn-sm" data-crm-card-layout-open-create-field="true">
                    <i class="bi bi-plus-circle me-1"></i> Создать поле
                </button>
            </div>

            <div class="small text-muted mb-2" data-crm-card-layout-selected-section-label="true">
                Выберите раздел, чтобы добавить поле
            </div>

            <div class="crm-card-layout__palette" data-crm-card-layout-palette="true"></div>

            <div class="crm-card-layout__builder-footer">
                <button type="button" class="btn btn-light border" data-crm-card-layout-cancel="true">Отмена</button>
                <button type="button" class="btn btn-primary" data-crm-card-layout-save="true">Сохранить layout</button>
            </div>
        </aside>
    </div>
</div>

<div class="modal fade" id="crmCardCreateFieldModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold">Новое поле</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <div id="crmCardCreateFieldForm">
                    <div class="p-3 bg-white rounded border">
                        <div class="mb-3">
                            <label class="form-label">Заголовок поля</label>
                            <input type="text" name="label" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Тип данных</label>
                            <select name="dataType" id="crmCardFieldDataTypeSelect" class="form-select">
                                @foreach (var type in Enum.GetValues<FieldDataType>())
                                {
                                    <option value="@((int)type)">@type.ToRuName()</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3 d-none" id="crmCardTargetEntityWrapper">
                            <label class="form-label">Целевая сущность</label>
                            <select name="targetEntityCode" id="crmCardTargetEntitySelect" class="form-select">
                                <option value="">-- Выберите объект --</option>
                                @foreach (var definition in Model.AllDefinitions)
                                {
                                    <option value="@definition.EntityCode">@definition.Name (@definition.EntityCode)</option>
                                }
                            </select>
                        </div>

                                    <input class="form-check-input" type="checkbox" name="isRequired" id="crmCardFieldRequired">
                                    <label class="form-check-label small" for="crmCardFieldRequired">Обязательное</label>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-check form-switch mt-2">
                                    <input class="form-check-input" type="checkbox" name="isArray" id="crmCardFieldArray">
                                    <label class="form-check-label small" for="crmCardFieldArray">Множественное</label>

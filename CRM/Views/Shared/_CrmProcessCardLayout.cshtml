@functions {
    IHtmlContent RenderDynamicFieldInput(AppFieldDefinition field, string value, bool hasError, Dictionary<string, List<SelectListItem>> lookupData, bool isRequired)
    {
        var fieldName = $"DynamicProps[{field.SystemName}]";
        var required = (isRequired && !field.IsArray) ? "required" : string.Empty;
        var errorClass = hasError ? "is-invalid" : string.Empty;

        switch (field.DataType)
        {
            case FieldDataType.EntityLink:
            case FieldDataType.Select:
                var options = new System.Text.StringBuilder();
                options.Append("<option value=\"\">-- Выберите --</option>");
                if (lookupData.TryGetValue(field.SystemName, out var items))
                {
                    foreach (var item in items)
                    {
                        var selected = item.Value == value ? "selected" : string.Empty;
                        options.Append($"<option value=\"{item.Value}\" {selected}>{item.Text}</option>");
                    }
                }

                if (!string.IsNullOrWhiteSpace(value) && (items == null || items.All(item => item.Value != value)))
                {
                    options.Append($"<option value=\"{value}\" selected>{value}</option>");
                }

                return new HtmlString($"<select name=\"{fieldName}\" class=\"form-control searchable-select {errorClass}\" data-search-placeholder=\"Поиск...\" {required}>{options}</select>");
            case FieldDataType.Number:
                return new HtmlString($"<input type=\"number\" step=\"any\" name=\"{fieldName}\" value=\"{NormalizeInputValue(value)}\" class=\"form-control {errorClass}\" {required} />");
            case FieldDataType.Money:
                return new HtmlString($"<input type=\"number\" step=\"0.01\" name=\"{fieldName}\" value=\"{NormalizeInputValue(value)}\" class=\"form-control {errorClass}\" placeholder=\"0.00\" {required} />");
            case FieldDataType.Date:
                return new HtmlString($"<input type=\"date\" name=\"{fieldName}\" value=\"{NormalizeDateValue(value)}\" class=\"form-control {errorClass}\" {required} />");
            case FieldDataType.DateTime:
                return new HtmlString($"<input type=\"datetime-local\" name=\"{fieldName}\" value=\"{NormalizeDateValue(value, true)}\" class=\"form-control {errorClass}\" {required} />");
            case FieldDataType.File:
                return new HtmlString($"<input type=\"file\" name=\"{fieldName}\" class=\"form-control {errorClass}\" {required} />");
            case FieldDataType.Boolean:
                var checkedAttr = string.Equals(value, "true", StringComparison.OrdinalIgnoreCase) ? "checked" : string.Empty;
                return new HtmlString($@"
                    <div class=""form-check form-switch mt-2"">
                        <input type=""hidden"" name=""{fieldName}"" value=""false"" />
                        <input class=""form-check-input"" type=""checkbox"" name=""{fieldName}"" value=""true"" {checkedAttr} />
                        <label class=""form-check-label"">Да</label>
                    </div>");
            case FieldDataType.Text:
                return new HtmlString($"<textarea name=\"{fieldName}\" class=\"form-control {errorClass}\" rows=\"3\" {required}>{value}</textarea>");
            default:
                return new HtmlString($"<input type=\"text\" name=\"{fieldName}\" value=\"{value}\" class=\"form-control {errorClass}\" {required} />");
        }
    }

    string? NormalizeInputValue(string? value) => value?.Replace(",", ".");

    string NormalizeDateValue(string? value, bool withTime = false)
    {
        if (DateTime.TryParse(value, out var parsed))
        {
            return parsed.ToString(withTime ? "yyyy-MM-ddTHH:mm" : "yyyy-MM-dd");
        }

        return string.Empty;
    }
}
